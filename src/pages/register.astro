---
export const prerender = false;
import { env } from "cloudflare:workers";
import { generatePbkdf2Hash, createSession, setSessionCookie, getCurrentUser, checkVerificationCode } from "../lib/auth.js";

const db = env.DB;

const existingUser = await getCurrentUser(db, Astro.cookies);
if (existingUser) return Astro.redirect("/");

const inviteCode = Astro.url.searchParams.get('code') || "";
let message = "";
let messageType = "error";
let submittedEmail = "";
let submittedUsername = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const email = data.get("email")?.toString().trim();
  const username = data.get("username")?.toString().trim();
  const password = data.get("password")?.toString();
  const verifyCode = data.get("verify_code")?.toString().trim();
  const submittedInviteCode = data.get("invite_code")?.toString().trim();

  submittedEmail = email;
  submittedUsername = username;

  if (!email || !username || !verifyCode) {
    message = "请填写必填项（邮箱、昵称、验证码）";
  } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    message = "邮箱格式不正确";
  } else {
    // 校验邮箱验证码，通过 checkVerificationCode 会自动销毁验证码
    const isCodeValid = await checkVerificationCode(db, email, verifyCode, 'register');
    
    if (!isCodeValid) {
      message = "验证码错误或已过期";
    } else {
      // 验证码正确，继续注册流程
      let finalRole = "user";
      
      const userCount = await db.prepare("SELECT COUNT(*) as cnt FROM users").first();
      if (userCount.cnt === 0) {
        finalRole = "owner";
      } else if (submittedInviteCode) {
        const inv = await db.prepare("SELECT * FROM invitations WHERE code = ? AND is_used = 0").bind(submittedInviteCode).first();
        if (inv) {
          finalRole = inv.role;
        } else {
          message = "⚠️ 管理员邀请码无效或已被使用，您此次无法注册为管理员。如果想注册纯用户，请清空邀请码。";
        }
      }

      if (!message) {
        let passwordHash = null;
        if (password && password.length >= 6) {
          passwordHash = await generatePbkdf2Hash(password);
        }

        try {
          const result = await db.prepare(
            "INSERT INTO users (email, username, password_hash, role) VALUES (?, ?, ?, ?)"
          ).bind(email, username, passwordHash, finalRole).run();

          const userId = result.meta.last_row_id;

          if (submittedInviteCode && finalRole !== "user") {
            await db.prepare("UPDATE invitations SET is_used = 1, used_by = ? WHERE code = ?").bind(username, submittedInviteCode).run();
          }

          const token = await createSession(db, userId);
          setSessionCookie(Astro.cookies, token);

          return Astro.redirect("/");
        } catch (e) {
          message = "注册失败：该邮箱可能已被注册。";
        }
      }
    }
  }
}
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>注册 - MyAnimeList</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="/toast.js" is:inline></script>
    <style>
        /* 复用登录/注册公共样式 */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', 'Noto Sans SC', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab); background-size: 400% 400%; animation: gradientBG 15s ease infinite; padding: 20px; }
        @keyframes gradientBG { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        .auth-card { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 28px; padding: 45px 40px; width: 100%; max-width: 420px; box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15); animation: slideUp 0.6s ease; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        .auth-header { text-align: center; margin-bottom: 25px; }
        .auth-header .logo { font-size: 2.5rem; margin-bottom: 8px; }
        .auth-header h1 { font-size: 1.6rem; color: #2d3436; font-weight: 700; margin-bottom: 6px; }
        .auth-header p { font-size: 0.9rem; color: #636e72; }
        .form-group { margin-bottom: 18px; position: relative; }
        .form-group label { display: block; font-size: 0.8rem; font-weight: 600; color: #636e72; margin-bottom: 8px; }
        .form-group input { width: 100%; padding: 14px 18px; border: 2px solid #e9ecef; border-radius: 14px; font-size: 0.95rem; font-family: inherit; transition: all 0.3s; background: rgba(255, 255, 255, 0.8); outline: none; }
        .form-group input:focus { border-color: #fb929e; box-shadow: 0 0 0 4px rgba(251, 146, 158, 0.15); }
        .send-code-btn { position: absolute; right: 5px; top: 31px; padding: 8px 12px; background: #e9ecef; color: #2d3436; border: none; border-radius: 10px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: 0.2s; }
        .send-code-btn:disabled { opacity: 0.6; cursor: not-allowed; }
        .submit-btn { width: 100%; padding: 15px; background: linear-gradient(135deg, #fb929e, #ff7f9f); color: white; border: none; border-radius: 14px; font-size: 1rem; font-weight: 700; font-family: inherit; cursor: pointer; transition: all 0.3s; margin-top: 5px; }
        .submit-btn:hover { box-shadow: 0 5px 15px rgba(251, 146, 158, 0.4); transform: translateY(-2px); }
        .message { text-align: center; padding: 12px; border-radius: 12px; margin-bottom: 18px; font-size: 0.85rem; font-weight: 500; background: rgba(214, 48, 49, 0.1); color: #d63031; }
        .auth-footer { text-align: center; margin-top: 22px; font-size: 0.85rem; color: #636e72; }
        .auth-footer a { color: #fb929e; text-decoration: none; font-weight: 600; transition: 0.2s; }
        .auth-footer a:hover { color: #ff7f9f; }
        .code-input-wrapper { display: flex; gap: 10px; }
        .code-input-wrapper input { flex: 1; }
        @media (prefers-color-scheme: dark) {
            .auth-card { background: rgba(30, 30, 30, 0.9); border-color: rgba(255, 255, 255, 0.1); }
            .auth-header h1 { color: #f5f5f7; }
            .auth-header p, .form-group label { color: #a0a0a0; }
            .form-group input { background: rgba(50, 50, 50, 0.8); border-color: rgba(255, 255, 255, 0.1); color: #f5f5f7; }
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-header">
            <div class="logo">✨</div>
            <h1>加入我们</h1>
            <p>通过邮箱创建你的追番账号</p>
        </div>

        {message && <div class="message">{message}</div>}

        <form method="POST" id="register-form">
            <div class="form-group">
                <label>电子邮箱</label>
                <input type="email" id="email" name="email" value={submittedEmail} placeholder="输入你的邮箱" required autocomplete="email" />
            </div>

            <div class="form-group">
                <label>邮箱验证码</label>
                <div class="code-input-wrapper">
                    <input type="text" name="verify_code" placeholder="6位数验证码" required autocomplete="off" maxlength="6" />
                    <button type="button" id="send-code-btn" class="send-code-btn" style="position:static; margin-top:3px; height: 46px;">获取验证码</button>
                </div>
            </div>

            <div class="form-group">
                <label>网站昵称</label>
                <input type="text" name="username" value={submittedUsername} placeholder="在站内展示的名称" required />
            </div>

            <div class="form-group">
                <label>登录密码 (可选)</label>
                <input type="password" name="password" placeholder="设置后可用于快捷登录，留空则只能验证码登录" autocomplete="new-password" />
            </div>

            <div class="form-group" style="padding-top:10px; border-top:1px dashed #ccc;">
                <label>🎟️ 邀请码 (仅管理员需要填写)</label>
                <input type="text" name="invite_code" value={inviteCode} placeholder="普通注册无需填写" />
            </div>

            <button type="submit" class="submit-btn">验证并注册</button>
        </form>

        <div class="auth-footer">
            已有账号？<a href="/login">去登录</a>
        </div>
    </div>

    <script is:inline>
        document.getElementById('send-code-btn').addEventListener('click', async function() {
            const email = document.getElementById('email').value.trim();
            if (!email) return window.showToast?.('请先填写邮箱地址');

            const btn = this;
            btn.disabled = true;
            btn.innerText = '发送中...';

            try {
                const res = await fetch('/api/send-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email, purpose: 'register' })
                });

                const data = await res.json();
                
                if (res.ok) {
                    window.showToast?.('验证码发送成功，请前往邮箱查收');
                    let countdown = 60;
                    const timer = setInterval(() => {
                        btn.innerText = `${countdown}s 后重发`;
                        countdown--;
                        if (countdown < 0) {
                            clearInterval(timer);
                            btn.disabled = false;
                            btn.innerText = '获取验证码';
                        }
                    }, 1000);
                } else {
                    window.showToast?.(data.error || '验证码发送失败', 'error');
                    btn.disabled = false;
                    btn.innerText = '获取验证码';
                }
            } catch (err) {
                window.showToast?.('网络错误，请稍后刷新重试', 'error');
                btn.disabled = false;
                btn.innerText = '获取验证码';
            }
        });
    </script>
</body>
</html>
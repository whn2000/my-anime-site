---
import { env } from "cloudflare:workers";

let message = "";

// 处理表单提交
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const title = data.get("title");
    const score = data.get("score");
    const status = data.get("status");
    const review = data.get("review");
    const image_url = data.get("image_url");

    const db = env.DB;
    
    // 执行插入语句
    await db.prepare(
      "INSERT INTO anime (title, score, status, review, image_url) VALUES (?, ?, ?, ?, ?)"
    ).bind(title, score, status, review, image_url).run();

    message = "✅ 添加成功！";
  } catch (e) {
    message = "❌ 出错了：" + e.message;
  }
}
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <title>后台管理 - 追番站</title>
    <style>
        body { font-family: sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; line-height: 1.6; }
        form { display: flex; flex-direction: column; gap: 15px; background: #fff; padding: 20px; border-radius: 8px; border: 1px solid #ddd; }
        input, textarea, select { padding: 10px; border: 1px solid #ccc; border-radius: 4px; }
        button { background: #0070f3; color: white; border: none; padding: 12px; border-radius: 4px; cursor: pointer; }
        .msg { color: green; font-weight: bold; }
        a { display: inline-block; margin-bottom: 20px; text-decoration: none; color: #666; }
    </style>
</head>
<body>
    <a href="/">← 返回首页</a>
    <h1>新增追番记录</h1>
    
    {message && <p class="msg">{message}</p>}

    <form method="POST">
        <input type="text" name="title" placeholder="番剧名称" required />
        <input type="number" step="0.1" name="score" placeholder="评分 (0-10)" required />
        <select name="status">
            <option value="正在追">正在追</option>
            <option value="已完结">已完结</option>
            <option value="想看">想看</option>
            <option value="弃番">弃番</option>
        </select>
        <input type="url" name="image_url" placeholder="封面图 URL (可选)" />
        <textarea name="review" placeholder="写下你的评价..." rows="4"></textarea>
        <button type="submit">立即发布</button>
    </form>
</body>
</html>
---
export const prerender = false;
import { env } from "cloudflare:workers";
import { getCurrentUser, hasRole, getRoleLabel } from "../lib/auth.js";

const db = env.DB;
const user = await getCurrentUser(db, Astro.cookies);

// 权限保护：仅站长和管理员可访问
if (!user || !hasRole(user, ['owner', 'admin'])) {
  return Astro.redirect("/login");
}

let message = "";
let backgroundUrl = '';

try {
  const bgSetting = await db.prepare("SELECT value FROM site_settings WHERE key = 'background_url'").first();
  if (bgSetting) backgroundUrl = bgSetting.value;
} catch (e) {}

// 1. 处理数据库操作（新增、删除、更新）
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = data.get("action");

    if (action === "save_settings" && user.role === 'owner') {
      const newBg = data.get("background_url");
      await db.prepare("INSERT INTO site_settings (key, value) VALUES ('background_url', ?) ON CONFLICT(key) DO UPDATE SET value=excluded.value").bind(newBg).run();
      message = "🌟 全站外观设置已更新！";
      backgroundUrl = newBg;
    } else if (action === "add") {
      const incomingTitle = data.get("title");
      const existing = await db.prepare("SELECT id FROM anime WHERE title = ?").bind(incomingTitle).first();
      
      if (existing) {
          message = "❌ 添加失败：该番剧已存在，禁止二次添加！";
      } else {
          // 先插入全局番剧信息
          const result = await db.prepare(
            "INSERT INTO anime (title, bgm_score, status, image_url, added_by, director, voice_actors, studio, review) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)"
          ).bind(
            incomingTitle, 
            data.get("bgm_score"), 
            data.get("status"), 
            data.get("image_url"),
            user.id,
            data.get("director"),
            data.get("voice_actors"),
            data.get("studio"),
            data.get("summary")
          ).run();
          
          const animeId = result.meta.last_row_id;

          // 插入个人独立评分
          await db.prepare(
            "INSERT INTO anime_scores (anime_id, user_id, score, review) VALUES (?, ?, ?, ?)"
          ).bind(
            animeId,
            user.id,
            data.get("score"),
            data.get("review")
          ).run();

          message = "✅ 发布成功！";
      }
    } else if (action === "update") {
      const animeId = data.get("id");
      // 更新全局信息
      await db.prepare(
        "UPDATE anime SET title = ?, bgm_score = ?, status = ?, image_url = ?, director = ?, voice_actors = ?, studio = ?, review = ? WHERE id = ?"
      ).bind(
        data.get("title"), 
        data.get("bgm_score"), 
        data.get("status"), 
        data.get("image_url"),
        data.get("director"),
        data.get("voice_actors"),
        data.get("studio"),
        data.get("summary"),
        animeId
      ).run();

      // 更新个人评分（UPSERT 功能）
      await db.prepare(`
        INSERT INTO anime_scores (anime_id, user_id, score, review)
        VALUES (?, ?, ?, ?)
        ON CONFLICT(anime_id, user_id) 
        DO UPDATE SET score = excluded.score, review = excluded.review
      `).bind(
        animeId,
        user.id,
        data.get("score"),
        data.get("review")
      ).run();

      message = "✨ 信息已更新！";
    } else if (action === "delete") {
      const animeId = data.get("id");
      // 检查权限：只有添加者或站长可以删除整部番剧
      const anime = await db.prepare("SELECT * FROM anime WHERE id = ?").bind(animeId).first();
      
      if (anime) {
        if (user.role === 'owner' || anime.added_by === user.id) {
          // 删除关联评分、评论和番剧
          await db.prepare("DELETE FROM anime_scores WHERE anime_id = ?").bind(animeId).run();
          await db.prepare("DELETE FROM comments WHERE anime_id = ?").bind(animeId).run();
          await db.prepare("DELETE FROM anime WHERE id = ?").bind(animeId).run();
          message = "🗑️ 记录已彻底删除";
        } else {
          message = "❌ 您没有权限删除此番剧，只有添加者或站长可删除全局记录。您可以删除自己的评分。";
        }
      }
    } else if (action === "delete_score") {
      const animeId = data.get("id");
      await db.prepare("DELETE FROM anime_scores WHERE anime_id = ? AND user_id = ?").bind(animeId, user.id).run();
      message = "🗑️ 您的个人评分已删除";
    } else if (action === 'batch_add') {
        const rawData = data.get('batch_data');
        const batchList = JSON.parse(rawData);
        if (batchList && batchList.length > 0) {
            const existingAnime = await db.prepare("SELECT title FROM anime").all();
            const existingTitles = new Set(existingAnime.results.map(a => a.title));
            const newAnimes = batchList.filter(item => !existingTitles.has(item.title));
            
            if (newAnimes.length > 0) {
                const stmts = newAnimes.map(item => {
                    let score = item.bgm_score || 0;
                    return db.prepare("INSERT INTO anime (title, score, bgm_score, status, review, image_url, added_by, director, voice_actors, studio) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)")
                        .bind(item.title, score, item.bgm_score, item.status, item.review, item.image_url, user.id, item.director, item.voice_actors, item.studio);
                });
                await db.batch(stmts);
                
                const skippedCount = batchList.length - newAnimes.length;
                if (skippedCount > 0) {
                    message = `✅ 批量导入成功！新增了 ${newAnimes.length} 部番剧，跳过了 ${skippedCount} 部已重复的。`;
                } else {
                    message = `✅ 批量导入成功！共新增 ${newAnimes.length} 部番剧。`;
                }
            } else {
                message = "ℹ️ 所选番剧已全部存在，未导入新数据（禁止二次添加）。";
            }
        }
    } else if (action === 'batch_delete') {
        const rawIds = data.get('batch_ids');
        if (rawIds) {
            const ids = rawIds.split(',').map(id => parseInt(id)).filter(id => !isNaN(id));
            if (ids.length > 0) {
                let deletedCount = 0;
                for (const id of ids) {
                    const anime = await db.prepare("SELECT added_by FROM anime WHERE id = ?").bind(id).first();
                    if (anime && (user.role === 'owner' || anime.added_by === user.id)) {
                        await db.batch([
                            db.prepare("DELETE FROM anime_scores WHERE anime_id = ?").bind(id),
                            db.prepare("DELETE FROM comments WHERE anime_id = ?").bind(id),
                            db.prepare("DELETE FROM anime WHERE id = ?").bind(id),
                        ]);
                        deletedCount++;
                    }
                }
                message = `🗑️ 成功批量删除了 ${deletedCount} 条记录`;
            }
        }
    } else if (action === 'batch_sync') {
        const rawData = data.get('sync_data');
        if (rawData) {
            const syncList = JSON.parse(rawData);
            if (syncList && syncList.length > 0) {
                const stmts = syncList.map(item => {
                    // 只更新bangumi获取的数据，站长和管理员的个人数据(score, review)及全局status均保持不变
                    return db.prepare("UPDATE anime SET bgm_score = ?, image_url = ?, director = ?, voice_actors = ?, studio = ?, review = ? WHERE id = ?")
                        .bind(item.bgm_score, item.image_url, item.director, item.voice_actors, item.studio, item.summary, item.id);
                });
                await db.batch(stmts);
                message = `🔄 成功批量更新了 ${syncList.length} 部番剧的 Bangumi 数据！主观信息保持不变。`;
            }
        }
    }
  } catch (e) {
    message = "❌ 数据库错误：" + e.message;
  }
}

// 2. 获取完整番剧列表以供编辑，包含当前用户的评分
const { results: rawAnimeList } = await db.prepare(`
  SELECT a.*, 
    (SELECT score FROM anime_scores WHERE anime_id = a.id AND user_id = ?) as my_score,
    (SELECT review FROM anime_scores WHERE anime_id = a.id AND user_id = ?) as my_review
  FROM anime a 
  ORDER BY a.id DESC
`).bind(user.id, user.id).all();

// 简单的转换以适应前端变量名
const animeList = rawAnimeList.map(a => ({
  ...a,
  score: a.my_score || '',
  summary: a.review || '',
  review: a.my_review || ''
}));

---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>管理后台 - MyAnimeList</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/opencc-js@1.0.5/dist/umd/full.js" defer></script>
    <script src="/toast.js" is:inline></script>
    <style>
        :root { --main: #fb929e; --edit: #ff7f9f; --glass: rgba(255,255,255,0.8); }
        body { font-family: 'Plus Jakarta Sans', 'Noto Sans SC', sans-serif; background: #fff5f7; padding: 20px; color: #333; }
        .box { max-width: 600px; margin: 0 auto; background: var(--glass); backdrop-filter: blur(20px); padding: 25px; border-radius: 20px; box-shadow: 0 10px 30px rgba(251, 146, 158, 0.1); border: 1px solid rgba(255,255,255,0.5); }
        .header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px dashed #fb929e; }
        .user-info { font-size: 14px; color: #666; font-weight: 600; }
        .user-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; background: #ffe4e8; color: var(--main); }
        .nav-links a { color: var(--main); text-decoration: none; font-size: 14px; margin-left: 15px; font-weight: 600; transition: 0.2s; }
        .nav-links a:hover { color: var(--edit); }
        .search-area { background: #fff0f3; padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #ffe4e8; }
        .res-box { border: 1px solid #ffe4e8; border-radius: 12px; display: none; margin-top: 10px; background: white; max-height: 300px; overflow-y: auto; box-shadow: 0 5px 15px rgba(251,146,158,0.1); }
        .item { display: flex; align-items: center; padding: 10px; cursor: pointer; border-bottom: 1px solid #fff0f3; gap: 10px; transition: 0.2s; }
        .item:hover { background: #fff0f3; }
        input, textarea, select { width: 100%; padding: 12px 15px; margin: 8px 0; border: 2px solid #ffe4e8; border-radius: 12px; box-sizing: border-box; font-size: 14px; font-family: inherit; transition: 0.3s; outline: none; background: rgba(255,255,255,0.9); }
        input:focus, textarea:focus, select:focus { border-color: var(--main); box-shadow: 0 0 0 4px rgba(251,146,158,0.15); }
        button { width: 100%; padding: 14px; border: none; border-radius: 12px; cursor: pointer; font-weight: 700; transition: all 0.3s; font-family: inherit; }
        .btn-blue { background: linear-gradient(135deg, var(--main), var(--edit)); color: white; box-shadow: 0 4px 15px rgba(251,146,158,0.3); }
        .btn-blue:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(251,146,158,0.4); }
        .btn-ghost { background: #fff0f3; color: var(--main); margin-top: 5px; font-size: 12px; }
        .list-item { display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px dashed #ffe4e8; border-radius: 10px; transition: 0.2s; }
        .list-item:hover { background: #fff0f3; transform: translateX(5px); }
        .badge { font-size: 10px; padding: 3px 8px; border-radius: 6px; background: #ffe4e8; color: var(--main); margin-left: 5px; font-weight: bold; }
        
        .dashboard { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-bottom: 25px; }
        .stat-card { background: linear-gradient(135deg, #fff, #fff0f3); padding: 20px; border-radius: 16px; border: 1px solid #ffe4e8; text-align: center; box-shadow: 0 4px 15px rgba(251,146,158,0.1); }
        .stat-card .num { font-size: 2rem; font-weight: 800; color: var(--main); margin-bottom: 5px; }
        .stat-card .lbl { font-size: 0.85rem; color: #666; font-weight: 600; }

        #anime-list-wrap { max-height: 500px; overflow-y: auto; padding-right: 5px; transition: max-height 0.3s ease; }
        #anime-list-wrap::-webkit-scrollbar { width: 6px; }
        #anime-list-wrap::-webkit-scrollbar-thumb { background: var(--main); border-radius: 3px; }

        @media (max-width: 600px) {
            body { padding: 10px; }
            .box { padding: 15px; }
            .dashboard { grid-template-columns: 1fr; }
            .header-bar { flex-direction: column; align-items: flex-start; gap: 15px; }
            .nav-links { display: flex; flex-wrap: wrap; gap: 10px; width: 100%; }
            .nav-links a { margin-left: 0; margin-right: 0; }
            .list-item { flex-direction: column; align-items: flex-start; gap: 12px; }
            .list-item > div:last-child { width: 100%; display: flex; justify-content: flex-end; flex-wrap: wrap; gap: 8px; }
            .search-area > div, form > div, .box > div { flex-wrap: wrap; }
            div[style*="display:flex"]:not(.list-item > div):not(.header-bar):not(.dashboard) { flex-direction: column; align-items: stretch !important; gap: 10px !important; }
            .search-area button { width: 100% !important; margin-top: 5px !important; }
            #batch-delete-form { margin-top: 10px !important; width: 100%; }
            #batch-delete-form button { width: 100% !important; }
        }
    </style>
</head>
<body>
    <div class="box">
        <div class="header-bar">
            <div class="user-info">
                <span>🌸 {user.username}</span>
                <span class="user-badge">{getRoleLabel(user.role)}</span>
            </div>
            <div class="nav-links">
                <a href="/">返回首页</a>
                {user.role === 'owner' && <a href="/invite" style="color: var(--edit);">🎟️ 邀请码设置</a>}
                <a href="/logout" style="color: #ff4757;">退出</a>
            </div>
        </div>

        {user.role === 'owner' && (
            <div class="dashboard">
                <div class="stat-card">
                    <div class="num">{animeList.length}</div>
                    <div class="lbl">收录番剧总数</div>
                </div>
                <div class="stat-card">
                    <div class="num">⭐</div>
                    <div class="lbl">后台管理中心</div>
                </div>
            </div>
        )}

        <h1 id="form-title">添加新番剧 🌸</h1>
        {message && <p style="color: #fff; text-align:center; font-weight:bold; margin-bottom:15px; padding:12px; background:var(--main); border-radius:12px;">{message}</p>}

        <div class="search-area" id="search-section">
            <label style="font-size:12px; color:#666;">第一步：从网络搜索填充 (可选)</label>
            <div style="display:flex; gap:10px;">
                <input type="text" id="kw" placeholder="输入番剧名 或 Bangumi ID..." style="margin:0" />
                <button type="button" onclick="doSearch()" id="sBtn" style="width:80px; margin:0; background:#333; color:white;">搜索</button>
            </div>
            <div id="res" class="res-box"></div>
        </div>

        <form method="POST" id="main-form">
            <input type="hidden" name="action" id="form-action" value="add" />
            <input type="hidden" name="id" id="form-id" />
            <input type="hidden" name="summary" id="bangumi-summary" />

            <input type="text" name="title" id="t" placeholder="番剧名称" required />
            <div style="display:flex; gap:10px;">
                <input type="number" step="0.1" min="0" max="10" name="score" id="s" placeholder="我的独立评分 (10分制)" required />
                <input type="number" step="0.1" min="0" max="10" name="bgm_score" id="bs" placeholder="Bangumi 官方评分" readonly style="background:#f9f9f9" />
            </div>
            
            <div style="display:flex; gap:10px;">
                <input type="text" name="director" id="dir" placeholder="导演" style="font-size:12px;" />
                <input type="text" name="studio" id="std" placeholder="动画制作" style="font-size:12px;" />
            </div>
            <input type="text" name="voice_actors" id="vas" placeholder="主要声优" style="font-size:12px;" />

            <select name="status" id="st">
                <option value="正在追">正在追</option>
                <option value="已完结">已完结</option>
                <option value="想看">想看</option>
                <option value="弃番">弃番</option>
            </select>
            <input type="url" name="image_url" id="img" placeholder="图片 URL" />
            <textarea name="review" id="rv" placeholder="我的独立评价..." rows="4"></textarea>
            
            <button type="submit" class="btn-blue" id="submit-btn" style="margin-top:10px;">发布到网站</button>
            <button type="button" class="btn-ghost" id="cancel-btn" style="display:none;" onclick="resetToAdd()">取消修改 / 返回新增</button>
        </form>

        <hr style="margin:40px 0; border:none; border-top:1px solid #eee;" />
        
        <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:15px;">
            <div>
                <h3 style="margin-bottom:5px; cursor:pointer; user-select:none; display:inline-flex; align-items:center; gap:6px;" onclick="toggleAnimeList()" title="点击折叠/展开列表">
                    已记录的番剧 ({animeList.length})
                    <span id="list-arrow" style="font-size:12px; color:#999; transition:transform 0.2s;">▼</span>
                </h3>
                <p style="font-size:12px; color:#999; margin:0;">你可以为所有番剧添加独立评分。若要删除整部番剧，仅限添加者或站长操作。</p>
            </div>
            <form method="POST" id="batch-delete-form" style="margin:0;">
                <input type="hidden" name="action" value="batch_delete" />
                <input type="hidden" name="batch_ids" id="batch-delete-ids" value="" />
                <button type="submit" class="btn-ghost" style="color:#ff4d4f; border:1px solid #ff4d4f; margin:0; padding:6px 12px;" onclick="return submitBatchDelete()">批量删除所选</button>
            </form>
        </div>
        
        <div id="anime-list-wrap">
        <div id="anime-list">
            {animeList.map(i => (
                <div class="list-item">
                    <div style="display:flex; align-items:center; gap:10px;">
                        {(user.role === 'owner' || i.added_by === user.id) && (
                            <input type="checkbox" class="anime-checkbox" value={i.id} style="margin:0; width:auto;" />
                        )}
                        <div>
                            <span style="font-size:14px; font-weight:500;">{i.title}</span>
                            <span class="badge">{i.status}</span>
                            {i.score ? <span style="font-size:12px; color:var(--main); margin-left:5px;">我的评分: {i.score}</span> : <span style="font-size:12px; color:#ccc; margin-left:5px;">未评分</span>}
                        </div>
                    </div>
                    <div style="display:flex; gap:10px;">
                        <button 
                            type="button" 
                            style="color:var(--main); background:none; border:none; cursor:pointer; font-size:13px;"
                            onclick={`prepareEdit(${JSON.stringify(i)})`}
                        >{i.score ? '编辑' : '评分'}</button>
                        
                        {(user.role === 'owner' || i.added_by === user.id) && (
                            <form method="POST" style="margin:0;">
                                <input type="hidden" name="action" value="delete" />
                                <input type="hidden" name="id" value={i.id} />
                                <button type="submit" style="color:#ff4d4f; background:none; border:none; cursor:pointer; font-size:13px;" onclick="return confirm('警告：这是全站删除！确定要永久删除整部番剧及其所有评分和评论吗？')">全局删除</button>
                            </form>
                        )}
                        {(! (user.role === 'owner' || i.added_by === user.id)) && i.score && (
                            <form method="POST" style="margin:0;">
                                <input type="hidden" name="action" value="delete_score" />
                                <input type="hidden" name="id" value={i.id} />
                                <button type="submit" style="color:#ff4d4f; background:none; border:none; cursor:pointer; font-size:13px;" onclick="return confirm('确定要删除您的个人评分吗？')">删评分</button>
                            </form>
                        )}
                    </div>
                </div>
            ))}
        </div>
        </div>
    </div>

    {user.role === 'owner' && (
      <div class="box" style="margin-top: 25px; border-left: 5px solid var(--main);">
        <h3 style="margin-top:0; color:var(--main);">✨ 批量智能扫雷（全自动抓取）</h3>
        <p style="font-size:12px; color:#666; margin-top:-10px;">输入想补充的番剧名称（每行一个）。系统将全自动连入 Bangumi 查找导演、声优、图片和详情。</p>
        <textarea id="batch-input" rows="5" placeholder="魔法少女小圆
某科学的超电磁炮
葬送的芙莉莲" style="width:100%; padding:10px; border:1px solid #ffe4e8; border-radius:12px; resize:vertical; box-sizing:border-box;"></textarea>
        
        <div style="display:flex; gap:10px; margin-top:10px; align-items:center;">
            <select id="batch-status" style="padding:10px; border-radius:8px; border:1px solid #ddd; outline:none; cursor:pointer;">
                <option value="已完结">导入状态默认：已完结</option>
                <option value="正在追">导入状态默认：正在追</option>
                <option value="想看">导入状态默认：想看</option>
            </select>
            <button type="button" class="btn-blue" onclick="startBatch()">🚀 开始全自动查档...</button>
        </div>
        
        <div id="batch-progress" style="margin-top:15px; font-size:12px; font-family:monospace; background:#fafafa; padding:10px; border-radius:8px; max-height:200px; overflow-y:auto; border:1px solid #eee; display:none;"></div>
        
        <form method="POST" id="batch-form" style="display:none; margin-top:15px; margin-bottom:0px;">
            <input type="hidden" name="action" value="batch_add" />
            <input type="hidden" name="batch_data" id="batch-data-input" />
            <button type="submit" class="btn-blue" style="background:#52c41a; width:100%; font-size:16px;">💾 获取完毕！点击将上方抓取的番剧一键写入数据库！</button>
        </form>
      </div>
    )}

    <div class="box" style="margin-top: 25px; border-left: 5px solid var(--edit);">
        <h3 style="margin-top:0; color:var(--edit);">🔄 一键更新 Bangumi 数据</h3>
        <p style="font-size:12px; color:#666; margin-top:-10px;">遍历所有已收录的番剧并同步 Bangumi 最新海报、评分和简介。</p>
        
        <div id="anime-data" style="display:none;" data-json={JSON.stringify(animeList.map(a => ({id: a.id, title: a.title})))}></div>
        <button type="button" class="btn-blue" style="background:var(--edit);" onclick="startBatchSync()">🔄 开始检测并同步...</button>
        
        <div id="sync-progress" style="margin-top:15px; font-size:12px; font-family:monospace; background:#fff0f3; padding:12px; border-radius:12px; max-height:200px; overflow-y:auto; border:1px solid #ffe4e8; display:none;"></div>
        
        <form method="POST" id="sync-form" style="display:none; margin-top:15px; margin-bottom:0px;">
            <input type="hidden" name="action" value="batch_sync" />
            <input type="hidden" name="sync_data" id="sync-data-input" />
            <button type="submit" class="btn-blue" style="background:#52c41a; width:100%; font-size:16px;">💾 抓取完毕！将数据写入库中</button>
        </form>
    </div>

    {user.role === 'owner' && (
      <div class="box" style="margin-top: 25px; border: 1px dashed var(--main);">
          <h3 style="margin-top:0;">🎨 全站外观设置</h3>
          <form method="POST">
              <input type="hidden" name="action" value="save_settings" />
              <label style="font-size:12px; color:#999; display:block; margin-bottom: 5px;">自定义首页背景大尺寸图片链接（建议 1920x1080 以上）</label>
              <input type="url" name="background_url" placeholder="https://..." value={backgroundUrl} />
              <button type="submit" class="btn-blue" style="margin-top:10px;">💾 保存界面设置</button>
          </form>
      </div>
    )}

    <script is:inline>
        let searchCache = [];

        async function fetchBangumiDetail(bgmId) {
            let dir = '', std = '', vas = '';
            try {
                const pRes = await fetch(`https://api.bgm.tv/v0/subjects/${bgmId}/persons`);
                const persons = await pRes.json();
                if(Array.isArray(persons)){
                    const d = persons.find(p => p.relation === '导演');
                    if(d) dir = d.name;
                    const s = persons.find(p => p.relation === '动画制作');
                    if(s) std = s.name;
                }
            } catch(e){}
            
            try {
                const cRes = await fetch(`https://api.bgm.tv/v0/subjects/${bgmId}/characters`);
                const chars = await cRes.json();
                if(Array.isArray(chars)){
                    const actorNames = [];
                    for(let c of chars) {
                        if(c.actors && c.actors.length > 0) actorNames.push(c.actors[0].name);
                        if(actorNames.length >= 3) break;
                    }
                    vas = actorNames.join(', ');
                }
            } catch(e){}
            
            return { dir, std, vas };
        }

        async function fetchBangumiSearch(originalKw) {
            let kw = originalKw.trim();

            if (/^\d+$/.test(kw)) {
                try {
                    const idRes = await fetch(`https://api.bgm.tv/subject/${kw}?responseGroup=large`);
                    const single = await idRes.json();
                    if (single && single.id) {
                        return { list: [single] };
                    }
                } catch(e) {}
            }

            try {
                if (typeof OpenCC !== 'undefined') {
                    const t2s = OpenCC.Converter({ from: 'tw', to: 'cn' });
                    kw = t2s(kw);
                }
            } catch(e) {}

            async function doFetch(term) {
                const res = await fetch(`https://api.bgm.tv/search/subject/${encodeURIComponent(term)}?type=2&responseGroup=large`);
                return await res.json();
            }

            try {
                let result = await doFetch(kw);
                if (result.list && result.list.length > 0) return result;
                
                // 模糊处理：去除副标题、括号内容、特殊标点后取核心词
                let fuzzyKw = kw.replace(/（[^）]*）|\([^)]*\)|\[[^\]]*\]|【[^】]*】/g, ''); 
                fuzzyKw = fuzzyKw.replace(/[第].*[季期]/g, ''); 
                fuzzyKw = fuzzyKw.split(' ')[0]; 
                fuzzyKw = fuzzyKw.split('：')[0]; 
                
                // 处理如果是类似 Re:从零开始 这种，如果前半部分太短则取全部去括号的版本
                if (fuzzyKw.length < 2) {
                     fuzzyKw = kw.replace(/（[^）]*）|\([^)]*\)|\[[^\]]*\]|【[^】]*】/g, '').replace(/[第].*[季期]/g, '').trim();
                }
                fuzzyKw = fuzzyKw.trim();

                if (fuzzyKw && fuzzyKw.length >= 2 && fuzzyKw !== kw) {
                     await new Promise(r => setTimeout(r, 600));
                     result = await doFetch(fuzzyKw);
                     if (result.list && result.list.length > 0) return result;
                }
                return {list: null};
            } catch(e) {
                return {list: null};
            }
        }

        async function doSearch() {
            const kw = document.getElementById('kw').value;
            if(!kw) return;
            
            const resBox = document.getElementById('res');
            resBox.style.display = 'block';
            resBox.innerHTML = '<div style="padding:10px;">🔍 正在直连 Bangumi...</div>';

            try {
                const result = await fetchBangumiSearch(kw);
                if (result.list && result.list.length > 0) {
                    searchCache = result.list;
                    resBox.innerHTML = searchCache.map((i, index) => {
                        const title = i.name_cn || i.name;
                        const sub = i.name_cn && i.name !== i.name_cn ? `| ${i.name}` : '';
                        const score = i.rating ? i.rating.score : 'N/A';
                        const year = i.air_date ? i.air_date.split('-')[0] : '';
                        const img = i.images ? i.images.common : '';
                        return `
                        <div class="item" onclick="selectSearchItem(${index})">
                            <img src="${img}" style="width:35px; height:50px; border-radius:4px; object-fit:cover;" />
                            <div>
                                <div style="font-weight:bold; font-size:12px;">${title} <span style="color:#999; font-size:10px; font-weight:normal;">${sub}</span></div>
                                <div style="font-size:10px; color:#999;">${year} | 评分: ${score}</div>
                            </div>
                        </div>
                    `}).join('');
                } else {
                    resBox.innerHTML = '<div style="padding:10px;">❌ 未找到结果 (请尝试更换更准确的名称)</div>';
                }
            } catch (err) {
                resBox.innerHTML = '<div style="padding:10px; color:red;">⚠️ 网络连接失败</div>';
            }
        }

        async function selectSearchItem(idx) {
            const item = searchCache[idx];
            document.getElementById('t').value = item.name_cn || item.name;
            document.getElementById('bs').value = item.rating && item.rating.score ? item.rating.score : 0;
            document.getElementById('img').value = item.images ? item.images.large || item.images.common : '';
            if (item.summary) {
                document.getElementById('bangumi-summary').value = item.summary.substring(0, 500) + "...";
            } else {
                document.getElementById('bangumi-summary').value = "";
            }
            
            document.getElementById('res').style.display = 'none';

            // Placeholder for deep fetching
            document.getElementById('dir').value = "获取中...";
            document.getElementById('std').value = "获取中...";
            document.getElementById('vas').value = "获取中...";

            const details = await fetchBangumiDetail(item.id);
            document.getElementById('dir').value = details.dir;
            document.getElementById('std').value = details.std;
            document.getElementById('vas').value = details.vas;
        }

        function submitBatchDelete() {
            const checkboxes = document.querySelectorAll('.anime-checkbox:checked');
            if (checkboxes.length === 0) {
                alert("请至少选择一个要删除的番剧！");
                return false;
            }
            if (!confirm(`确定要永久删除这 ${checkboxes.length} 部番剧及其所有评分和评论吗？`)) {
                return false;
            }
            const ids = Array.from(checkboxes).map(c => c.value).join(',');
            document.getElementById('batch-delete-ids').value = ids;
            return true;
        }

        function prepareEdit(item) {
            document.getElementById('form-title').innerText = "正在编辑：" + item.title;
            document.getElementById('form-action').value = "update";
            document.getElementById('form-id').value = item.id;
            document.getElementById('submit-btn').innerText = "保存我的评分及番剧信息";
            document.getElementById('submit-btn').style.background = "#f09199";
            document.getElementById('cancel-btn').style.display = "block";
            
            document.getElementById('t').value = item.title;
            document.getElementById('s').value = item.score; // 可能是空的
            document.getElementById('bs').value = item.bgm_score;
            document.getElementById('st').value = item.status;
            document.getElementById('img').value = item.image_url;
            document.getElementById('dir').value = item.director || '';
            document.getElementById('vas').value = item.voice_actors || '';
            document.getElementById('std').value = item.studio || '';
            document.getElementById('rv').value = item.review;
            document.getElementById('bangumi-summary').value = item.summary;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function toggleAnimeList() {
            const wrap = document.getElementById('anime-list-wrap');
            const arrow = document.getElementById('list-arrow');
            if (wrap.style.display === 'none') {
                wrap.style.display = 'block';
                arrow.style.transform = 'rotate(0deg)';
            } else {
                wrap.style.display = 'none';
                arrow.style.transform = 'rotate(-90deg)';
            }
        }

        function resetToAdd() {
            document.getElementById('form-title').innerText = "添加新番剧";
            document.getElementById('form-action').value = "add";
            document.getElementById('form-id').value = "";
            document.getElementById('submit-btn').innerText = "发布到网站";
            document.getElementById('submit-btn').style.background = "#3dbbee";
            document.getElementById('cancel-btn').style.display = "none";
            document.getElementById('bangumi-summary').value = "";
            document.getElementById('main-form').reset();
        }

        async function startBatch() {
            const lines = document.getElementById('batch-input').value.split('\n').map(l => l.trim()).filter(l => l);
            if (lines.length === 0) return alert("请先输入需要查询的动漫名单");
            
            const status = document.getElementById('batch-status').value;
            const prog = document.getElementById('batch-progress');
            prog.style.display = 'block';
            prog.innerHTML = '';
            document.getElementById('batch-form').style.display = 'none';
            const batchList = [];
            
            for (let i = 0; i < lines.length; i++) {
                const title = lines[i];

                prog.innerHTML += `<div style="color:#555;">⏳ [${i+1}/${lines.length}] 正在深度搜索：<b>${title}</b>...</div>`;
                prog.scrollTop = prog.scrollHeight;
                
                try {
                    const result = await fetchBangumiSearch(title);
                    
                    if (result.list && result.list.length > 0) {
                        const bgm = result.list[0];
                        const details = await fetchBangumiDetail(bgm.id);
                        
                        const item = {
                            title: bgm.name_cn || bgm.name,
                            bgm_score: (bgm.rating && bgm.rating.score) ? bgm.rating.score : 0,
                            image_url: bgm.images ? bgm.images.large || bgm.images.common : '',
                            review: bgm.summary ? bgm.summary.substring(0, 500) + "..." : "",
                            status: status,
                            director: details.dir,
                            studio: details.std,
                            voice_actors: details.vas
                        };
                        batchList.push(item);
                        prog.innerHTML += `<div style="color:#52c41a; margin-bottom:8px;">✅ 抓取成功: <b>${item.title}</b> (Bgm: ${item.bgm_score}) 导演: ${details.dir}</div>`;
                    } else {
                        prog.innerHTML += `<div style="color:#f5222d; margin-bottom:8px;">❌ 数据库未收录此作品: ${title}</div>`;
                    }
                } catch(e) {
                    prog.innerHTML += `<div style="color:#f5222d; margin-bottom:8px;">❌ 网络中断，跳过抓取: ${title}</div>`;
                }
                
                prog.scrollTop = prog.scrollHeight;
                // 防止封IP，严格限速延迟
                await new Promise(r => setTimeout(r, 600)); 
            }
            
            prog.innerHTML += `<div style="color:#1890ff; margin-top:10px;">🎉 全部处理完毕！共组装好 ${batchList.length} 条记录。</div>`;
            prog.scrollTop = prog.scrollHeight;
            
            if(batchList.length > 0) {
                document.getElementById('batch-data-input').value = JSON.stringify(batchList);
                document.getElementById('batch-form').style.display = 'block';
            }
        }

        async function startBatchSync() {
            const animeDataNode = document.getElementById('anime-data');
            if (!animeDataNode) return;
            const currentAnimes = JSON.parse(animeDataNode.getAttribute('data-json') || '[]');
            if (currentAnimes.length === 0) return alert("当前没有任何番剧可更新");
            
            const prog = document.getElementById('sync-progress');
            prog.style.display = 'block';
            prog.innerHTML = '';
            document.getElementById('sync-form').style.display = 'none';
            const syncList = [];
            
            for (let i = 0; i < currentAnimes.length; i++) {
                const item = currentAnimes[i];
                prog.innerHTML += `<div style="color:#555;">⏳ [${i+1}/${currentAnimes.length}] 正在同步：<b>${item.title}</b>...</div>`;
                prog.scrollTop = prog.scrollHeight;
                
                try {
                    const result = await fetchBangumiSearch(item.title);
                    if (result.list && result.list.length > 0) {
                        const bgm = result.list[0];
                        const details = await fetchBangumiDetail(bgm.id);
                        
                        syncList.push({
                            id: item.id,
                            bgm_score: (bgm.rating && bgm.rating.score) ? bgm.rating.score : 0,
                            image_url: bgm.images ? bgm.images.large || bgm.images.common : '',
                            summary: bgm.summary ? bgm.summary.substring(0, 500) + "..." : "",
                            director: details.dir,
                            studio: details.std,
                            voice_actors: details.vas
                        });
                        prog.innerHTML += `<div style="color:#52c41a; margin-bottom:8px;">✅ 更新完毕: <b>${item.title}</b> (Bgm: ${(bgm.rating && bgm.rating.score) ? bgm.rating.score : 0})</div>`;
                    } else {
                        prog.innerHTML += `<div style="color:#faad14; margin-bottom:8px;">⚠️ 无法找到对应数据，跳过: ${item.title}</div>`;
                    }
                } catch(e) {
                    prog.innerHTML += `<div style="color:#f5222d; margin-bottom:8px;">❌ 网络中断，跳过更新: ${item.title}</div>`;
                }
                
                prog.scrollTop = prog.scrollHeight;
                // 防止封IP，严格限速延迟
                await new Promise(r => setTimeout(r, 600)); 
            }
            
            prog.innerHTML += `<div style="color:#1890ff; margin-top:10px;">🎉 全部处理完毕！共已获取 ${syncList.length} 条番剧的最新 Bangumi 数据。</div>`;
            prog.scrollTop = prog.scrollHeight;
            
            if(syncList.length > 0) {
                document.getElementById('sync-data-input').value = JSON.stringify(syncList);
                document.getElementById('sync-form').style.display = 'block';
            }
        }
    </script>


---
export const prerender = false; // 1. 强制该页面为 SSR 模式

import { env } from "cloudflare:workers";

const db = env.DB;
let message = "";

// --- 处理服务端逻辑 ---

// A. 处理搜索请求 (通过 URL 参数 ?q=关键字 触发)
const url = new URL(Astro.request.url);
const searchQuery = url.searchParams.get("q");

if (searchQuery) {
  try {
    const bgmRes = await fetch(
      `https://api.bgm.tv/v0/search/subjects?keywords=${encodeURIComponent(searchQuery)}&limit=5&type=2`,
      { headers: { 'User-Agent': 'whn2000-anime-tracker/1.0' } }
    );
    const data = await bgmRes.json();
    return new Response(JSON.stringify(data), {
      headers: { "Content-Type": "application/json" }
    });
  } catch (e) {
    return new Response(JSON.stringify({ error: e.message }), { status: 500 });
  }
}

// B. 处理 POST 请求 (新增/删除)
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = data.get("action");

    if (action === "add") {
      await db.prepare(
        "INSERT INTO anime (title, score, bgm_score, status, review, image_url) VALUES (?, ?, ?, ?, ?, ?)"
      ).bind(
        data.get("title"), 
        data.get("score"), 
        data.get("bgm_score"), 
        data.get("status"), 
        data.get("review"), 
        data.get("image_url")
      ).run();
      message = "✅ 发布成功！";
    } else if (action === "delete") {
      await db.prepare("DELETE FROM anime WHERE id = ?").bind(data.get("id")).run();
      message = "🗑️ 记录已删除";
    }
  } catch (e) {
    message = "❌ 错误：" + e.message;
  }
}

// 获取现有列表
const { results: animeList } = await db.prepare("SELECT id, title FROM anime ORDER BY id DESC").all();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>后台管理 - 动态版</title>
    <style>
        :root { --primary: #f09199; }
        body { font-family: sans-serif; background: #fdfdfd; padding: 20px; }
        .container { max-width: 600px; margin: 0 auto; }
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.05); margin-bottom: 20px; border: 1px solid #eee; }
        .search-bar { display: flex; gap: 8px; margin-bottom: 15px; }
        .search-results { border: 1px solid #eee; border-radius: 8px; display: none; margin-bottom: 20px; background: #fff; overflow: hidden; }
        .result-item { display: flex; align-items: center; padding: 10px; cursor: pointer; border-bottom: 1px solid #f9f9f9; gap: 12px; }
        .result-item:hover { background: #fff5f6; }
        .result-item img { width: 45px; height: 60px; object-fit: cover; border-radius: 4px; }
        form { display: flex; flex-direction: column; gap: 12px; }
        input, textarea, select { padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; }
        .btn-submit { background: var(--primary); color: white; border: none; padding: 14px; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .btn-del { color: #ff4757; background: none; border: 1px solid #ff4757; padding: 4px 10px; border-radius: 6px; cursor: pointer; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/" style="text-decoration: none; color: #999; font-size: 14px;">← 首页预览</a>
        
        <div class="card" style="margin-top: 10px;">
            <h2 style="margin-top:0">管理我的追番列表</h2>
            {message && <div style="color: #065f46; background: #d1fae5; padding: 10px; border-radius: 8px; margin-bottom: 15px;">{message}</div>}

            <div class="search-bar">
                <input type="text" id="kw" placeholder="输入番剧名搜索..." style="flex:1" />
                <button type="button" onclick="search()" id="sBtn" style="padding:0 20px; border-radius:8px; border:none; background:#444; color:white; cursor:pointer;">搜索</button>
            </div>
            <div id="res" class="search-results"></div>

            <form method="POST" action="/admin">
                <input type="hidden" name="action" value="add" />
                <input type="text" name="title" id="t" placeholder="名称" required />
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <input type="number" step="0.1" name="score" placeholder="我的评分" required />
                    <input type="number" step="0.1" name="bgm_score" id="bs" placeholder="Bgm 官方分" readonly style="background:#f9f9f9" />
                </div>
                <select name="status">
                    <option value="正在追">正在追</option>
                    <option value="已完结">已完结</option>
                    <option value="想看">想看</option>
                </select>
                <input type="url" name="image_url" id="img" placeholder="海报 URL" />
                <textarea name="review" id="rv" placeholder="简评..." rows="3"></textarea>
                <button type="submit" class="btn-submit">保存发布</button>
            </form>
        </div>

        <div class="card">
            <h3>现有列表 ({animeList.length})</h3>
            {animeList.map(item => (
                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f9f9f9; align-items:center;">
                    <span style="font-size: 14px; color: #444;">{item.title}</span>
                    <form method="POST" action="/admin" style="margin:0;">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="id" value={item.id} />
                        <button type="submit" class="btn-del" onclick="return confirm('确定要删除这条记录吗？')">删除</button>
                    </form>
                </div>
            ))}
        </div>
    </div>

    <script is:inline>
        async function search() {
            const kw = document.getElementById('kw').value;
            if(!kw) return;
            const btn = document.getElementById('sBtn');
            const resBox = document.getElementById('res');
            btn.innerText = '...';
            resBox.style.display = 'block';
            resBox.innerHTML = '<div style="padding:15px; font-size:14px; color:#666;">正在搜索 Bangumi 数据库...</div>';
            
            try {
                // 关键点：请求本页面的服务端代理，避免跨域
                const r = await fetch(`/admin?q=${encodeURIComponent(kw)}`);
                const d = await r.json();
                if(d.data && d.data.length > 0) {
                    resBox.innerHTML = d.data.map(i => `
                        <div class="result-item" onclick="pick(${i.id})">
                            <img src="${i.images.small}" />
                            <div>
                                <div style="font-weight:bold; font-size:14px;">${i.name_cn || i.name}</div>
                                <div style="font-size:12px; color:#999;">${i.date || '未知年份'}</div>
                            </div>
                        </div>
                    `).join('');
                } else { resBox.innerHTML = '<div style="padding:15px;">无结果</div>'; }
            } catch (e) { resBox.innerHTML = '<div style="padding:15px;">搜索失败</div>'; }
            finally { btn.innerText = '搜索'; }
        }

        async function pick(id) {
            const r = await fetch(`https://api.bgm.tv/v0/subjects/${id}`);
            const d = await r.json();
            document.getElementById('t').value = d.name_cn || d.name;
            document.getElementById('bs').value = d.rating.score || 0;
            document.getElementById('img').value = d.images.large;
            document.getElementById('rv').value = d.summary ? d.summary.substring(0, 80) + '...' : '';
            document.getElementById('res').style.display = 'none';
        }
    </script>
</body>
</html>
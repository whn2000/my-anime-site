---
export const prerender = false;
import { env } from "cloudflare:workers";
import { getCurrentUser, hasRole, getRoleLabel } from "../lib/auth.js";

const db = env.DB;
const user = await getCurrentUser(db, Astro.cookies);

// 权限保护：仅站长和管理员可访问
if (!user || !hasRole(user, ['owner', 'admin'])) {
  return Astro.redirect("/login");
}

let message = "";
let backgroundUrl = '';

try {
  const bgSetting = await db.prepare("SELECT value FROM site_settings WHERE key = 'background_url'").first();
  if (bgSetting) backgroundUrl = bgSetting.value;
} catch (e) {}

// 1. 处理数据库操作（新增、删除、更新）
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = data.get("action");

    if (action === "save_settings" && user.role === 'owner') {
      const newBg = data.get("background_url");
      await db.prepare("INSERT INTO site_settings (key, value) VALUES ('background_url', ?) ON CONFLICT(key) DO UPDATE SET value=excluded.value").bind(newBg).run();
      message = "🌟 全站外观设置已更新！";
      backgroundUrl = newBg;
    } else if (action === "add") {
      // 先插入全局番剧信息
      const result = await db.prepare(
        "INSERT INTO anime (title, bgm_score, status, image_url, added_by, director, voice_actors, studio) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
      ).bind(
        data.get("title"), 
        data.get("bgm_score"), 
        data.get("status"), 
        data.get("image_url"),
        user.id,
        data.get("director"),
        data.get("voice_actors"),
        data.get("studio")
      ).run();
      
      const animeId = result.meta.last_row_id;

      // 插入个人独立评分
      await db.prepare(
        "INSERT INTO anime_scores (anime_id, user_id, score, review) VALUES (?, ?, ?, ?)"
      ).bind(
        animeId,
        user.id,
        data.get("score"),
        data.get("review")
      ).run();

      message = "✅ 发布成功！";
    } else if (action === "update") {
      const animeId = data.get("id");
      // 更新全局信息
      await db.prepare(
        "UPDATE anime SET title = ?, bgm_score = ?, status = ?, image_url = ?, director = ?, voice_actors = ?, studio = ? WHERE id = ?"
      ).bind(
        data.get("title"), 
        data.get("bgm_score"), 
        data.get("status"), 
        data.get("image_url"),
        data.get("director"),
        data.get("voice_actors"),
        data.get("studio"),
        animeId
      ).run();

      // 更新个人评分（UPSERT 功能）
      await db.prepare(`
        INSERT INTO anime_scores (anime_id, user_id, score, review)
        VALUES (?, ?, ?, ?)
        ON CONFLICT(anime_id, user_id) 
        DO UPDATE SET score = excluded.score, review = excluded.review
      `).bind(
        animeId,
        user.id,
        data.get("score"),
        data.get("review")
      ).run();

      message = "✨ 信息已更新！";
    } else if (action === "delete") {
      const animeId = data.get("id");
      // 检查权限：只有添加者或站长可以删除整部番剧
      const anime = await db.prepare("SELECT * FROM anime WHERE id = ?").bind(animeId).first();
      
      if (anime) {
        if (user.role === 'owner' || anime.added_by === user.id) {
          // 删除关联评分、评论和番剧
          await db.prepare("DELETE FROM anime_scores WHERE anime_id = ?").bind(animeId).run();
          await db.prepare("DELETE FROM comments WHERE anime_id = ?").bind(animeId).run();
          await db.prepare("DELETE FROM anime WHERE id = ?").bind(animeId).run();
          message = "🗑️ 记录已彻底删除";
        } else {
          message = "❌ 您没有权限删除此番剧，只有添加者或站长可删除全局记录。您可以删除自己的评分。";
        }
      }
    } else if (action === "delete_score") {
      const animeId = data.get("id");
      await db.prepare("DELETE FROM anime_scores WHERE anime_id = ? AND user_id = ?").bind(animeId, user.id).run();
      message = "🗑️ 您的个人评分已删除";
    }
  } catch (e) {
    message = "❌ 数据库错误：" + e.message;
  }
}

// 2. 获取完整番剧列表以供编辑，包含当前用户的评分
const { results: rawAnimeList } = await db.prepare(`
  SELECT a.*, 
    (SELECT score FROM anime_scores WHERE anime_id = a.id AND user_id = ?) as my_score,
    (SELECT review FROM anime_scores WHERE anime_id = a.id AND user_id = ?) as my_review
  FROM anime a 
  ORDER BY a.id DESC
`).bind(user.id, user.id).all();

// 简单的转换以适应前端变量名
const animeList = rawAnimeList.map(a => ({
  ...a,
  score: a.my_score || '',
  review: a.my_review || ''
}));

---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>管理后台 - MyAnimeList</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        :root { --main: #3dbbee; --edit: #f09199; }
        body { font-family: 'Plus Jakarta Sans', 'Noto Sans SC', sans-serif; background: #f4f7f6; padding: 20px; color: #333; }
        .box { max-width: 600px; margin: 0 auto; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
        .user-info { font-size: 14px; color: #666; }
        .user-badge { display: inline-block; padding: 3px 8px; border-radius: 6px; font-size: 12px; font-weight: bold; background: #eef9ff; color: var(--main); }
        .nav-links a { color: var(--main); text-decoration: none; font-size: 14px; margin-left: 15px; }
        .search-area { background: #eef9ff; padding: 15px; border-radius: 10px; margin-bottom: 20px; }
        .res-box { border: 1px solid #eee; border-radius: 8px; display: none; margin-top: 10px; background: white; max-height: 300px; overflow-y: auto; }
        .item { display: flex; align-items: center; padding: 10px; cursor: pointer; border-bottom: 1px solid #f0f0f0; gap: 10px; }
        .item:hover { background: #f0faff; }
        input, textarea, select { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 14px; font-family: inherit; }
        button { width: 100%; padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; transition: 0.2s; font-family: inherit; }
        .btn-blue { background: var(--main); color: white; }
        .btn-ghost { background: #eee; color: #666; margin-top: 5px; font-size: 12px; }
        .list-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #f9f9f9; }
        .badge { font-size: 10px; padding: 2px 6px; border-radius: 4px; background: #eee; margin-left: 5px; }

        @media (max-width: 600px) {
            body { padding: 10px; }
            .box { padding: 15px; }
            .header-bar { flex-direction: column; align-items: flex-start; gap: 15px; }
            .nav-links a { margin-left: 0; margin-right: 15px; }
            .list-item { flex-direction: column; align-items: flex-start; gap: 12px; }
            .list-item > div:last-child { width: 100%; display: flex; justify-content: flex-end; }
        }
    </style>
</head>
<body>
    <div class="box">
        <div class="header-bar">
            <div class="user-info">
                <span>👤 {user.username}</span>
                <span class="user-badge">{getRoleLabel(user.role)}</span>
            </div>
            <div class="nav-links">
                <a href="/">返回首页</a>
                {user.role === 'owner' && <a href="/invite" style="color: #f09199;">🎟️ 邀请码设置</a>}
                <a href="/logout" style="color: #999;">退出</a>
            </div>
        </div>

        <h1 id="form-title">添加新番剧</h1>
        {message && <p style="color: #3dbbee; text-align:center; font-weight:bold; margin-bottom:15px; padding:10px; background:#eef9ff; border-radius:8px;">{message}</p>}

        <div class="search-area" id="search-section">
            <label style="font-size:12px; color:#666;">第一步：从网络搜索填充 (可选)</label>
            <div style="display:flex; gap:10px;">
                <input type="text" id="kw" placeholder="输入番剧名..." style="margin:0" />
                <button type="button" onclick="doSearch()" id="sBtn" style="width:80px; margin:0; background:#333; color:white;">搜索</button>
            </div>
            <div id="res" class="res-box"></div>
        </div>

        <form method="POST" id="main-form">
            <input type="hidden" name="action" id="form-action" value="add" />
            <input type="hidden" name="id" id="form-id" />
            <input type="hidden" name="director" id="dir" />
            <input type="hidden" name="voice_actors" id="vas" />
            <input type="hidden" name="studio" id="std" />

            <input type="text" name="title" id="t" placeholder="番剧名称" required />
            <div style="display:flex; gap:10px;">
                <input type="number" step="0.1" name="score" id="s" placeholder="我的独立评分 (10分制)" required />
                <input type="number" step="0.1" name="bgm_score" id="bs" placeholder="官方评分" readonly style="background:#f9f9f9" />
            </div>
            <select name="status" id="st">
                <option value="正在追">正在追</option>
                <option value="已完结">已完结</option>
                <option value="想看">想看</option>
                <option value="弃番">弃番</option>
            </select>
            <input type="url" name="image_url" id="img" placeholder="图片 URL" />
            <textarea name="review" id="rv" placeholder="我的独立评价..." rows="4"></textarea>
            
            <button type="submit" class="btn-blue" id="submit-btn" style="margin-top:10px;">发布到网站</button>
            <button type="button" class="btn-ghost" id="cancel-btn" style="display:none;" onclick="resetToAdd()">取消修改 / 返回新增</button>
        </form>

        <hr style="margin:40px 0; border:none; border-top:1px solid #eee;" />
        
        <h3>已记录的番剧 ({animeList.length})</h3>
        <p style="font-size:12px; color:#999; margin-bottom:15px;">你可以为所有番剧添加独立评分。若要删除整部番剧（包括他人的评分/评论），仅限添加者或站长操作。</p>
        
        <div id="anime-list">
            {animeList.map(i => (
                <div class="list-item">
                    <div>
                        <span style="font-size:14px; font-weight:500;">{i.title}</span>
                        <span class="badge">{i.status}</span>
                        {i.score ? <span style="font-size:12px; color:var(--main); margin-left:5px;">我的评分: {i.score}</span> : <span style="font-size:12px; color:#ccc; margin-left:5px;">未评分</span>}
                    </div>
                    <div style="display:flex; gap:10px;">
                        <button 
                            type="button" 
                            style="color:var(--main); background:none; border:none; cursor:pointer; font-size:13px;"
                            onclick={`prepareEdit(${JSON.stringify(i)})`}
                        >{i.score ? '编辑' : '评分'}</button>
                        
                        {(user.role === 'owner' || i.added_by === user.id) && (
                            <form method="POST" style="margin:0;">
                                <input type="hidden" name="action" value="delete" />
                                <input type="hidden" name="id" value={i.id} />
                                <button type="submit" style="color:#ff4d4f; background:none; border:none; cursor:pointer; font-size:13px;" onclick="return confirm('警告：这是全站删除！确定要永久删除整部番剧及其所有评分和评论吗？')">全局删除</button>
                            </form>
                        )}
                        {(! (user.role === 'owner' || i.added_by === user.id)) && i.score && (
                            <form method="POST" style="margin:0;">
                                <input type="hidden" name="action" value="delete_score" />
                                <input type="hidden" name="id" value={i.id} />
                                <button type="submit" style="color:#ff4d4f; background:none; border:none; cursor:pointer; font-size:13px;" onclick="return confirm('确定要删除您的个人评分吗？')">删评分</button>
                            </form>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>

    {user.role === 'owner' && (
      <div class="box" style="margin-top: 25px; border: 1px solid #eef9ff;">
          <h3 style="margin-top:0;">🎨 全站外观设置</h3>
          <form method="POST">
              <input type="hidden" name="action" value="save_settings" />
              <label style="font-size:12px; color:#999; display:block; margin-bottom: 5px;">自定义首页背景大尺寸图片链接（建议 1920x1080 以上）</label>
              <input type="url" name="background_url" placeholder="https://..." value={backgroundUrl} />
              <button type="submit" class="btn-blue" style="margin-top:10px;">💾 保存界面设置</button>
          </form>
      </div>
    )}

    <script is:inline>
        let searchCache = [];

        async function doSearch() {
            const kw = document.getElementById('kw').value;
            if(!kw) return;
            const resBox = document.getElementById('res');
            resBox.style.display = 'block';
            resBox.innerHTML = '<div style="padding:10px;">🔍 正在直连 AniList...</div>';

            const query = `query($s:String){Page(perPage:5){media(search:$s,type:ANIME){id title{english romaji native}coverImage{large}averageScore description startDate{year} studios(isMain:true){nodes{name}} staff{edges{role node{name{full}}}} characters(sort:ROLE,perPage:3){edges{voiceActors(language:JAPANESE){name{full}}}}}}}`;
            try {
                const response = await fetch('https://graphql.anilist.co', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ query, variables: { s: kw } })
                });
                const result = await response.json();
                if (result.data?.Page?.media?.length > 0) {
                    searchCache = result.data.Page.media;
                    resBox.innerHTML = searchCache.map((i, index) => `
                        <div class="item" onclick="selectSearchItem(${index})">
                            <img src="${i.coverImage.large}" style="width:35px; height:50px; border-radius:4px;" />
                            <div>
                                <div style="font-weight:bold; font-size:12px;">${i.title.english || i.title.native}</div>
                                <div style="font-size:10px; color:#999;">${i.startDate.year || ''} | 评分: ${i.averageScore || 'N/A'}</div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    resBox.innerHTML = '<div style="padding:10px;">❌ 未找到结果</div>';
                }
            } catch (err) {
                resBox.innerHTML = '<div style="padding:10px; color:red;">⚠️ 网络连接失败</div>';
            }
        }

        function selectSearchItem(idx) {
            const item = searchCache[idx];
            document.getElementById('t').value = item.title.english || item.title.native;
            document.getElementById('bs').value = item.averageScore ? (item.averageScore / 10).toFixed(1) : 0;
            document.getElementById('img').value = item.coverImage.large;
            document.getElementById('rv').value = item.description ? item.description.replace(/<[^>]*>?/gm, '').substring(0, 150) + "..." : "";
            
            const director = item.staff?.edges?.find(e => e.role?.toLowerCase().includes('director'))?.node?.name?.full || '';
            const vas = item.characters?.edges?.map(e => e.voiceActors?.[0]?.name?.full).filter(Boolean).slice(0,3).join(', ') || '';
            const studio = item.studios?.nodes?.[0]?.name || '';
            
            document.getElementById('dir').value = director;
            document.getElementById('vas').value = vas;
            document.getElementById('std').value = studio;
            
            document.getElementById('res').style.display = 'none';
        }

        function prepareEdit(item) {
            document.getElementById('form-title').innerText = "正在编辑：" + item.title;
            document.getElementById('form-action').value = "update";
            document.getElementById('form-id').value = item.id;
            document.getElementById('submit-btn').innerText = "保存我的评分及番剧信息";
            document.getElementById('submit-btn').style.background = "#f09199";
            document.getElementById('cancel-btn').style.display = "block";
            
            document.getElementById('t').value = item.title;
            document.getElementById('s').value = item.score; // 可能是空的
            document.getElementById('bs').value = item.bgm_score;
            document.getElementById('st').value = item.status;
            document.getElementById('img').value = item.image_url;
            document.getElementById('dir').value = item.director || '';
            document.getElementById('vas').value = item.voice_actors || '';
            document.getElementById('std').value = item.studio || '';
            document.getElementById('rv').value = item.review;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function resetToAdd() {
            document.getElementById('form-title').innerText = "添加新番剧";
            document.getElementById('form-action').value = "add";
            document.getElementById('form-id').value = "";
            document.getElementById('submit-btn').innerText = "发布到网站";
            document.getElementById('submit-btn').style.background = "#3dbbee";
            document.getElementById('cancel-btn').style.display = "none";
            document.getElementById('main-form').reset();
        }
    </script>
</body>
</html>
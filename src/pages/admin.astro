---
export const prerender = false;
import { env } from "cloudflare:workers";

const db = env.DB;
let message = "";

// 1. 处理数据库操作（新增、删除、更新）
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = data.get("action");

    if (action === "add") {
      await db.prepare(
        "INSERT INTO anime (title, score, bgm_score, status, review, image_url) VALUES (?, ?, ?, ?, ?, ?)"
      ).bind(
        data.get("title"), 
        data.get("score"), 
        data.get("bgm_score"), 
        data.get("status"), 
        data.get("review"), 
        data.get("image_url")
      ).run();
      message = "✅ 发布成功！";
    } else if (action === "update") {
      await db.prepare(
        "UPDATE anime SET title = ?, score = ?, bgm_score = ?, status = ?, review = ?, image_url = ? WHERE id = ?"
      ).bind(
        data.get("title"), 
        data.get("score"), 
        data.get("bgm_score"), 
        data.get("status"), 
        data.get("review"), 
        data.get("image_url"),
        data.get("id")
      ).run();
      message = "✨ 信息已更新！";
    } else if (action === "delete") {
      await db.prepare("DELETE FROM anime WHERE id = ?").bind(data.get("id")).run();
      message = "🗑️ 记录已删除";
    }
  } catch (e) {
    message = "❌ 数据库错误：" + e.message;
  }
}

// 2. 获取完整番剧列表以供编辑 
const { results: animeList } = await db.prepare("SELECT * FROM anime ORDER BY id DESC").all();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>管理后台 - 增强版</title>
    <style>
        :root { --main: #3dbbee; --edit: #f09199; }
        body { font-family: sans-serif; background: #f4f7f6; padding: 20px; color: #333; }
        .box { max-width: 600px; margin: 0 auto; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .search-area { background: #eef9ff; padding: 15px; border-radius: 10px; margin-bottom: 20px; }
        .res-box { border: 1px solid #eee; border-radius: 8px; display: none; margin-top: 10px; background: white; max-height: 300px; overflow-y: auto; }
        .item { display: flex; align-items: center; padding: 10px; cursor: pointer; border-bottom: 1px solid #f0f0f0; gap: 10px; }
        .item:hover { background: #f0faff; }
        input, textarea, select { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 14px; }
        button { width: 100%; padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; transition: 0.2s; }
        .btn-blue { background: var(--main); color: white; }
        .btn-ghost { background: #eee; color: #666; margin-top: 5px; font-size: 12px; }
        .list-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #f9f9f9; }
        .badge { font-size: 10px; padding: 2px 6px; border-radius: 4px; background: #eee; margin-left: 5px; }
    </style>
</head>
<body>
    <div class="box">
        <a href="/" style="color:#999; font-size:14px; text-decoration:none;">← 返回首页</a>
        <h1 id="form-title">添加新番剧</h1>
        {message && <p style="color: #3dbbee; text-align:center; font-weight:bold;">{message}</p>}

        <div class="search-area" id="search-section">
            <label style="font-size:12px; color:#666;">第一步：从网络搜索填充 (可选)</label>
            <div style="display:flex; gap:10px;">
                <input type="text" id="kw" placeholder="输入番剧名..." style="margin:0" />
                <button type="button" onclick="doSearch()" id="sBtn" style="width:80px; margin:0; background:#333; color:white;">搜索</button>
            </div>
            <div id="res" class="res-box"></div>
        </div>

        <form method="POST" action="/admin" id="main-form">
            <input type="hidden" name="action" id="form-action" value="add" />
            <input type="hidden" name="id" id="form-id" />

            <input type="text" name="title" id="t" placeholder="番剧名称" required />
            <div style="display:flex; gap:10px;">
                <input type="number" step="0.1" name="score" id="s" placeholder="我的评分" required />
                <input type="number" step="0.1" name="bgm_score" id="bs" placeholder="官方评分" readonly style="background:#f9f9f9" />
            </div>
            <select name="status" id="st">
                <option value="正在追">正在追</option>
                <option value="已完结">已完结</option>
                <option value="想看">想看</option>
                <option value="弃番">弃番</option>
            </select>
            <input type="url" name="image_url" id="img" placeholder="图片 URL" />
            <textarea name="review" id="rv" placeholder="你的评价..." rows="4"></textarea>
            
            <button type="submit" class="btn-blue" id="submit-btn">发布到网站</button>
            <button type="button" class="btn-ghost" id="cancel-btn" style="display:none;" onclick="resetToAdd()">取消修改 / 返回新增</button>
        </form>

        <hr style="margin:40px 0; border:none; border-top:1px solid #eee;" />
        
        <h3>已记录的番剧 ({animeList.length})</h3>
        <div id="anime-list">
            {animeList.map(i => (
                <div class="list-item">
                    <div>
                        <span style="font-size:14px; font-weight:500;">{i.title}</span>
                        <span class="badge">{i.status}</span>
                    </div>
                    <div style="display:flex; gap:15px;">
                        <button 
                            type="button" 
                            style="color:var(--main); background:none; border:none; cursor:pointer; font-size:13px;"
                            onclick={`prepareEdit(${JSON.stringify(i)})`}
                        >编辑</button>
                        
                        <form method="POST" action="/admin" style="margin:0;">
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="id" value={i.id} />
                            <button type="submit" style="color:#ff4d4f; background:none; border:none; cursor:pointer; font-size:13px;" onclick="return confirm('确定要永久删除这条记录吗？')">删除</button>
                        </form>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <script is:inline>
        let searchCache = [];

        async function doSearch() {
            const kw = document.getElementById('kw').value;
            if(!kw) return;
            const resBox = document.getElementById('res');
            resBox.style.display = 'block';
            resBox.innerHTML = '<div style="padding:10px;">🔍 正在直连 AniList...</div>';

            const query = `query($s:String){Page(perPage:5){media(search:$s,type:ANIME){id title{english romaji native}coverImage{large}averageScore description startDate{year}}}}`;
            try {
                const response = await fetch('https://graphql.anilist.co', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ query, variables: { s: kw } })
                });
                const result = await response.json();
                if (result.data?.Page?.media?.length > 0) {
                    searchCache = result.data.Page.media;
                    resBox.innerHTML = searchCache.map((i, index) => `
                        <div class="item" onclick="selectSearchItem(${index})">
                            <img src="${i.coverImage.large}" style="width:35px; height:50px; border-radius:4px;" />
                            <div>
                                <div style="font-weight:bold; font-size:12px;">${i.title.english || i.title.native}</div>
                                <div style="font-size:10px; color:#999;">${i.startDate.year || ''} | 评分: ${i.averageScore || 'N/A'}</div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    resBox.innerHTML = '<div style="padding:10px;">❌ 未找到结果</div>';
                }
            } catch (err) {
                resBox.innerHTML = '<div style="padding:10px; color:red;">⚠️ 网络连接失败</div>';
            }
        }

        function selectSearchItem(idx) {
            const item = searchCache[idx];
            document.getElementById('t').value = item.title.english || item.title.native;
            document.getElementById('bs').value = item.averageScore ? (item.averageScore / 10).toFixed(1) : 0;
            document.getElementById('img').value = item.coverImage.large;
            document.getElementById('rv').value = item.description ? item.description.replace(/<[^>]*>?/gm, '').substring(0, 150) + "..." : "";
            document.getElementById('res').style.display = 'none';
        }

        function prepareEdit(item) {
            document.getElementById('form-title').innerText = "正在编辑：" + item.title;
            document.getElementById('form-action').value = "update";
            document.getElementById('form-id').value = item.id;
            document.getElementById('submit-btn').innerText = "保存修改";
            document.getElementById('submit-btn').style.background = "#f09199";
            document.getElementById('cancel-btn').style.display = "block";
            
            document.getElementById('t').value = item.title;
            document.getElementById('s').value = item.score;
            document.getElementById('bs').value = item.bgm_score;
            document.getElementById('st').value = item.status;
            document.getElementById('img').value = item.image_url;
            document.getElementById('rv').value = item.review;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function resetToAdd() {
            document.getElementById('form-title').innerText = "添加新番剧";
            document.getElementById('form-action').value = "add";
            document.getElementById('form-id').value = "";
            document.getElementById('submit-btn').innerText = "发布到网站";
            document.getElementById('submit-btn').style.background = "#3dbbee";
            document.getElementById('cancel-btn').style.display = "none";
            document.getElementById('main-form').reset();
        }
    </script>
</body>
</html>
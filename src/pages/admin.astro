            const batchList = [];
            
            for (let i = 0; i < lines.length; i++) {
                const title = lines[i];

                prog.innerHTML += `<div style="color:#555;">⏳ [${i+1}/${lines.length}] 正在深度搜索：<b>${title}</b>...</div>`;
                prog.scrollTop = prog.scrollHeight;
                
                try {
                    const result = await fetchBangumiSearch(title);
                    
                    if (result.list && result.list.length > 0) {
                        const bgm = result.list[0];
                        // Secondary queries for depth
                        let dir = '', std = '', vas = '';
                        try {
                            const pRes = await fetch(`https://api.bgm.tv/v0/subjects/${bgm.id}/persons`);
                            const persons = await pRes.json();
                            if(Array.isArray(persons)){
                                const d = persons.find(p => p.relation === '导演');
                                if(d) dir = d.name;
                                const s = persons.find(p => p.relation === '动画制作');
                                if(s) std = s.name;
                            }
                        } catch(e){}
                        
                        try {
                            const cRes = await fetch(`https://api.bgm.tv/v0/subjects/${bgm.id}/characters`);
                            const chars = await cRes.json();
                            if(Array.isArray(chars)){
                                const actorNames = [];
                                for(let c of chars) {
                                    if(c.actors && c.actors.length > 0) actorNames.push(c.actors[0].name);
                                    if(actorNames.length >= 3) break;
                                }
                                vas = actorNames.join(', ');
                            }
                        } catch(e){}
                        
                        const item = {
                            title: bgm.name_cn || bgm.name,
                            bgm_score: (bgm.rating && bgm.rating.score) ? bgm.rating.score : 0,
                            image_url: bgm.images ? bgm.images.large || bgm.images.common : '',
                            review: bgm.summary ? bgm.summary.substring(0, 500) + "..." : "",
                            status: status,
                            director: dir,
                            studio: std,
                            voice_actors: vas
                        };
                        batchList.push(item);
                        prog.innerHTML += `<div style="color:#52c41a; margin-bottom:8px;">✅ 抓取成功: <b>${item.title}</b> (Bgm: ${item.bgm_score}) 导演: ${dir}</div>`;
                    } else {
                        prog.innerHTML += `<div style="color:#f5222d; margin-bottom:8px;">❌ 数据库未收录此作品: ${title}</div>`;
                    }
                } catch(e) {
                    prog.innerHTML += `<div style="color:#f5222d; margin-bottom:8px;">❌ 网络中断，跳过抓取: ${title}</div>`;
                }
                
                prog.scrollTop = prog.scrollHeight;
                // 防止封IP，严格限速延迟
                await new Promise(r => setTimeout(r, 600)); 
            }
            
            prog.innerHTML += `<div style="color:#1890ff; margin-top:10px;">🎉 全部处理完毕！共组装好 ${batchList.length} 条记录。</div>`;
            prog.scrollTop = prog.scrollHeight;
            
            if(batchList.length > 0) {
                document.getElementById('batch-data-input').value = JSON.stringify(batchList);
                document.getElementById('batch-form').style.display = 'block';
            }
        }

        async function startBatchSync() {
            const animeDataNode = document.getElementById('anime-data');
            if (!animeDataNode) return;
            const currentAnimes = JSON.parse(animeDataNode.getAttribute('data-json') || '[]');
            if (currentAnimes.length === 0) return alert("当前没有任何番剧可更新");
            
            const prog = document.getElementById('sync-progress');
            prog.style.display = 'block';
            prog.innerHTML = '';
            document.getElementById('sync-form').style.display = 'none';
            const syncList = [];
            
            for (let i = 0; i < currentAnimes.length; i++) {
                const item = currentAnimes[i];
                prog.innerHTML += `<div style="color:#555;">⏳ [${i+1}/${currentAnimes.length}] 正在同步：<b>${item.title}</b>...</div>`;
                prog.scrollTop = prog.scrollHeight;
                
                try {
                    const result = await fetchBangumiSearch(item.title);
                    if (result.list && result.list.length > 0) {
                        const bgm = result.list[0];
                        let dir = '', std = '', vas = '';
                        try {
                            const pRes = await fetch(`https://api.bgm.tv/v0/subjects/${bgm.id}/persons`);
                            const persons = await pRes.json();
                            if(Array.isArray(persons)){
                                const d = persons.find(p => p.relation === '导演');
                                if(d) dir = d.name;
                                const s = persons.find(p => p.relation === '动画制作');
                                if(s) std = s.name;
                            }
                        } catch(e){}
                        
                        try {
                            const cRes = await fetch(`https://api.bgm.tv/v0/subjects/${bgm.id}/characters`);
                            const chars = await cRes.json();
                            if(Array.isArray(chars)){
                                const actorNames = [];
                                for(let c of chars) {
                                    if(c.actors && c.actors.length > 0) actorNames.push(c.actors[0].name);
                                    if(actorNames.length >= 3) break;
                                }
                                vas = actorNames.join(', ');
                            }
                        } catch(e){}
                        
                        syncList.push({
                            id: item.id,
                            bgm_score: (bgm.rating && bgm.rating.score) ? bgm.rating.score : 0,
                            image_url: bgm.images ? bgm.images.large || bgm.images.common : '',
                            summary: bgm.summary ? bgm.summary.substring(0, 500) + "..." : "",
                            director: dir,
                            studio: std,
                            voice_actors: vas
                        });
                        prog.innerHTML += `<div style="color:#52c41a; margin-bottom:8px;">✅ 更新完毕: <b>${item.title}</b> (Bgm: ${(bgm.rating && bgm.rating.score) ? bgm.rating.score : 0})</div>`;
                    } else {
                        prog.innerHTML += `<div style="color:#faad14; margin-bottom:8px;">⚠️ 无法找到对应数据，跳过: ${item.title}</div>`;
                    }
                } catch(e) {
                    prog.innerHTML += `<div style="color:#f5222d; margin-bottom:8px;">❌ 网络中断，跳过更新: ${item.title}</div>`;
                }
                
                prog.scrollTop = prog.scrollHeight;
                // 防止封IP，严格限速延迟
                await new Promise(r => setTimeout(r, 600)); 
            }
            
            prog.innerHTML += `<div style="color:#1890ff; margin-top:10px;">🎉 全部处理完毕！共已获取 ${syncList.length} 条番剧的最新 Bangumi 数据。</div>`;
            prog.scrollTop = prog.scrollHeight;
            
            if(syncList.length > 0) {
                document.getElementById('sync-data-input').value = JSON.stringify(syncList);
                document.getElementById('sync-form').style.display = 'block';
            }
        }
    </script>
</body>

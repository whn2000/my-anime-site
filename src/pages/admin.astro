---
export const prerender = false;
import { env } from "cloudflare:workers";

const db = env.DB;
let message = "";

// 仅处理数据库插入和删除
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const action = data.get("action");

    if (action === "add") {
      await db.prepare(
        "INSERT INTO anime (title, score, bgm_score, status, review, image_url) VALUES (?, ?, ?, ?, ?, ?)"
      ).bind(
        data.get("title"), 
        data.get("score"), 
        data.get("bgm_score"), 
        data.get("status"), 
        data.get("review"), 
        data.get("image_url")
      ).run();
      message = "✅ 发布成功！";
    } else if (action === "delete") {
      await db.prepare("DELETE FROM anime WHERE id = ?").bind(data.get("id")).run();
      message = "🗑️ 记录已删除";
    }
  } catch (e) {
    message = "❌ 数据库错误：" + e.message;
  }
}

const { results: animeList } = await db.prepare("SELECT id, title FROM anime ORDER BY id DESC").all();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>管理后台 - 兼容版</title>
    <style>
        :root { --main: #3dbbee; }
        body { font-family: sans-serif; background: #f4f7f6; padding: 20px; }
        .box { max-width: 600px; margin: 0 auto; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        .search-area { background: #eef9ff; padding: 15px; border-radius: 10px; margin-bottom: 20px; }
        .res-box { border: 1px solid #eee; border-radius: 8px; display: none; margin-top: 10px; background: white; }
        .item { display: flex; align-items: center; padding: 10px; cursor: pointer; border-bottom: 1px solid #f0f0f0; gap: 10px; }
        .item:hover { background: #f0faff; }
        input, textarea, select { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .btn-blue { background: var(--main); color: white; }
        .btn-black { background: #333; color: white; margin-top: 5px; }
    </style>
</head>
<body>
    <div class="box">
        <a href="/" style="color:#999; font-size:14px;">← 返回首页</a>
        <h1>追番表管理</h1>
        {message && <p style="color: blue; text-align:center;">{message}</p>}

        <div class="search-area">
            <label style="font-size:12px; color:#666;">第一步：搜索 (支持中文，推荐英文)</label>
            <div style="display:flex; gap:10px;">
                <input type="text" id="kw" placeholder="输入番剧名..." style="margin:0" />
                <button type="button" onclick="doSearch()" id="sBtn" style="width:80px; margin:0; background:#333; color:white;">搜索</button>
            </div>
            <div id="res" class="res-box"></div>
        </div>

        <form method="POST" action="/admin">
            <input type="hidden" name="action" value="add" />
            <input type="text" name="title" id="t" placeholder="标题" required />
            <div style="display:flex; gap:10px;">
                <input type="number" step="0.1" name="score" placeholder="我的评分" required />
                <input type="number" step="0.1" name="bgm_score" id="bs" placeholder="官方分" readonly style="background:#f9f9f9" />
            </div>
            <select name="status">
                <option value="正在追">正在追</option>
                <option value="已完结">已完结</option>
                <option value="想看">想看</option>
            </select>
            <input type="url" name="image_url" id="img" placeholder="图片 URL" />
            <textarea name="review" id="rv" placeholder="评价内容..." rows="3"></textarea>
            <button type="submit" class="btn-blue">发布到网站</button>
        </form>

        <hr style="margin:30px 0; border:none; border-top:1px solid #eee;" />
        
        <h3>管理现有番剧</h3>
        {animeList.map(i => (
            <div style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid #f9f9f9;">
                <span style="font-size:14px;">{i.title}</span>
                <form method="POST" action="/admin" style="margin:0;">
                    <input type="hidden" name="action" value="delete" /><input type="hidden" name="id" value={i.id} />
                    <button type="submit" style="color:red; background:none; border:none; cursor:pointer;" onclick="return confirm('确定删除？')">删除</button>
                </form>
            </div>
        ))}
    </div>

    <script is:inline>
        let cache = [];

        // --- 核心：直接在浏览器请求 AniList ---
        async function doSearch() {
            const kw = document.getElementById('kw').value;
            if(!kw) return;
            const resBox = document.getElementById('res');
            resBox.style.display = 'block';
            resBox.innerHTML = '<div style="padding:10px;">🔍 正在直连 AniList 数据库...</div>';

            const query = `query($s:String){Page(perPage:5){media(search:$s,type:ANIME){id title{english romaji native}coverImage{large}averageScore description startDate{year}}}}`;

            try {
                const response = await fetch('https://graphql.anilist.co', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'Accept': 'application/json'},
                    body: JSON.stringify({ query, variables: { s: kw } })
                });
                
                const result = await response.json();
                console.log('AniList Raw Data:', result); // 你可以在浏览器控制台看到原始数据

                if (result.data?.Page?.media?.length > 0) {
                    cache = result.data.Page.media;
                    resBox.innerHTML = cache.map((i, index) => `
                        <div class="item" onclick="selectItem(${index})">
                            <img src="${i.coverImage.large}" style="width:40px; height:55px; border-radius:4px;" />
                            <div>
                                <div style="font-weight:bold; font-size:13px;">${i.title.english || i.title.romaji || i.title.native}</div>
                                <div style="font-size:11px; color:#999;">${i.startDate.year || ''} | 评分: ${i.averageScore || '无'}</div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    resBox.innerHTML = '<div style="padding:10px;">❌ 没找到结果，试着输入英文名字。</div>';
                }
            } catch (err) {
                console.error(err);
                resBox.innerHTML = '<div style="padding:10px; color:red;">⚠️ 无法连接 AniList，请检查网络访问。</div>';
            }
        }

        function selectItem(idx) {
            const item = cache[idx];
            document.getElementById('t').value = item.title.english || item.title.romaji || item.title.native;
            document.getElementById('bs').value = item.averageScore ? (item.averageScore / 10).toFixed(1) : 0;
            document.getElementById('img').value = item.coverImage.large;
            document.getElementById('rv').value = item.description ? item.description.replace(/<[^>]*>?/gm, '').substring(0, 100) + "..." : "";
            document.getElementById('res').style.display = 'none';
        }
    </script>
</body>
</html>
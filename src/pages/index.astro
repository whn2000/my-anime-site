---
import { env } from "cloudflare:workers";
const db = env.DB;

// 获取番剧列表
const { results: animeList } = await db.prepare("SELECT * FROM anime ORDER BY id DESC").all();

// 状态颜色映射逻辑
const getStatusTheme = (status) => {
    const map = {
        '已完结': { bg: '#e3f2fd', text: '#1976d2', darkBg: '#1e3a5f', darkText: '#90caf9' },
        '正在追': { bg: '#e8f5e9', text: '#2e7d32', darkBg: '#1b3a1e', darkText: '#a5d6a7' },
        '想看': { bg: '#fff3e0', text: '#ef6c00', darkBg: '#3e2723', darkText: '#ffcc80' },
        '弃番': { bg: '#ffebee', text: '#c62828', darkBg: '#3e1b1b', darkText: '#ef9a9a' }
    };
    return map[status] || { bg: '#eee', text: '#666', darkBg: '#333', darkText: '#bbb' };
};
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>我的追番记录</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #f09199;
            --bg: #f8f9fa;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-sub: #636e72;
            --border: rgba(0,0,0,0.05);
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #121212;
                --card-bg: #1e1e1e;
                --text-main: #e0e0e0;
                --text-sub: #a0a0a0;
                --border: rgba(255,255,255,0.1);
            }
        }

        body { 
            font-family: 'Noto Sans SC', sans-serif; 
            background: var(--bg); 
            color: var(--text-main);
            margin: 0; padding: 40px 20px;
        }

        .grid { 
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
            gap: 25px; max-width: 1200px; margin: 0 auto;
        }

        .card { 
            background: var(--card-bg);
            border-radius: 20px; overflow: hidden; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            border: 1px solid var(--border);
            transition: transform 0.3s ease;
        }
        .card:hover { transform: translateY(-5px); }

        .cover-box { position: relative; height: 380px; }
        .cover { width: 100%; height: 100%; object-fit: cover; }

        .status-badge {
            position: absolute; top: 12px; right: 12px;
            padding: 4px 12px; border-radius: 8px;
            font-size: 0.75rem; font-weight: bold;
            backdrop-filter: blur(4px);
        }

        .content { padding: 15px; }
        
        /* 标题点击样式 */
        .title { 
            font-size: 1.2rem; margin: 0 0 10px 0; 
            cursor: pointer; 
            transition: color 0.2s;
            display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;
        }
        .title:hover { color: var(--primary); text-decoration: underline; }

        .scores { font-size: 0.9rem; margin-bottom: 10px; display: flex; gap: 10px; }
        .review-preview { 
            font-size: 0.85rem; color: var(--text-sub);
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        }

        /* 弹窗样式 */
        dialog {
            border: none;
            border-radius: 20px;
            padding: 0;
            max-width: 500px;
            width: 90%;
            background: var(--card-bg);
            color: var(--text-main);
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        dialog::backdrop {
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(5px);
        }
        .modal-content { padding: 30px; position: relative; }
        .close-btn {
            position: absolute; top: 20px; right: 20px;
            background: none; border: none; font-size: 1.5rem;
            cursor: pointer; color: var(--text-sub);
        }
        .modal-cover { width: 100%; border-radius: 12px; margin-bottom: 20px; }

        .footer { text-align: center; margin-top: 50px; color: var(--text-sub); font-size: 0.8rem; }
    </style>
</head>
<body>
    <div style="text-align: center; margin-bottom: 40px;">
        <h1>我的追番列表 📺</h1>
        <p style="color: var(--text-sub);">点击番剧名字查看详情</p>
    </div>

    <div class="grid">
        {animeList.map((anime) => {
            const theme = getStatusTheme(anime.status);
            return (
                <div class="card">
                    <div class="cover-box">
                        <span class="status-badge" style={`background: ${theme.bg}; color: ${theme.text};`}>
                            {anime.status}
                        </span>
                        <img src={anime.image_url} alt={anime.title} class="cover" />
                    </div>
                    <div class="content">
                        <h2 class="title" 
                            data-title={anime.title} 
                            data-full-review={anime.review} 
                            data-img={anime.image_url}
                            data-score={anime.score}
                            data-bgm={anime.bgm_score}
                        >
                            {anime.title}
                        </h2>
                        <div class="scores">
                            <span style="color: #ff9800;">⭐ {anime.score}</span>
                            <span style="color: var(--primary);">📍 Bgm: {anime.bgm_score}</span>
                        </div>
                        <p class="review-preview">{anime.review}</p>
                    </div>
                </div>
            );
        })}
    </div>

    <dialog id="anime-dialog">
        <div class="modal-content">
            <button class="close-btn" id="close-dialog">&times;</button>
            <img id="modal-img" class="modal-cover" src="" alt="" />
            <h2 id="modal-title" style="margin-top: 0;"></h2>
            <div id="modal-scores" style="margin-bottom: 15px; font-weight: bold;"></div>
            <p id="modal-review" style="line-height: 1.6; white-space: pre-wrap;"></p>
        </div>
    </dialog>

    <div class="footer">
        Powered by Astro & Cloudflare D1
    </div>

    <script>
        const dialog = document.getElementById('anime-dialog');
        const closeBtn = document.getElementById('close-dialog');
        const titles = document.querySelectorAll('.title');

        // 获取弹窗内的元素
        const mImg = document.getElementById('modal-img');
        const mTitle = document.getElementById('modal-title');
        const mScores = document.getElementById('modal-scores');
        const mReview = document.getElementById('modal-review');

        titles.forEach(title => {
            title.addEventListener('click', () => {
                // 从 data 属性中提取数据并填充到弹窗
                mImg.src = title.dataset.img;
                mTitle.textContent = title.dataset.title;
                mScores.innerHTML = `⭐ 我评: ${title.dataset.score} | 📍 AniList: ${title.dataset.bgm}`;
                mReview.textContent = title.dataset.fullReview || "暂无详细评论...";
                
                dialog.showModal(); // 显示弹窗
            });
        });

        closeBtn.addEventListener('click', () => {
            dialog.close();
        });

        // 点击背景关闭
        dialog.addEventListener('click', (e) => {
            if (e.target === dialog) dialog.close();
        });
    </script>
</body>
</html>
---
import { env } from "cloudflare:workers";
const db = env.DB;
const { results: animeList } = await db.prepare("SELECT * FROM anime ORDER BY id DESC").all();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>我的追番记录 - MyAnimeList</title>
    <style>
        :root { --primary: #f09199; }
        body { font-family: -apple-system, sans-serif; background: #f0f2f5; margin: 0; padding: 40px 20px; }
        .header { text-align: center; margin-bottom: 40px; }
        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
            gap: 25px; 
            max-width: 1200px; 
            margin: 0 auto; 
        }
        .card { 
            background: white; 
            border-radius: 15px; 
            overflow: hidden; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            transition: 0.3s;
        }
        .card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
        .cover { width: 100%; height: 380px; object-fit: cover; background: #ddd; }
        .content { padding: 15px; }
        .title { font-size: 1.2rem; font-weight: bold; margin: 0 0 10px 0; color: #333; }
        .scores { display: flex; gap: 15px; margin-bottom: 12px; font-size: 0.9rem; }
        .my-score { color: #ff9800; font-weight: bold; }
        .bgm-score { color: var(--primary); font-weight: bold; }
        .status-badge { 
            display: inline-block; 
            padding: 2px 8px; 
            background: #eee; 
            border-radius: 4px; 
            font-size: 0.75rem; 
            color: #666; 
            margin-bottom: 10px;
        }
        .review { font-size: 0.9rem; color: #555; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }
        .footer { text-align: center; margin-top: 50px; color: #999; font-size: 0.8rem; }
    </style>
</head>
<body>
    <div class="header">
        <h1>我的追番列表 📺</h1>
        <p>记录生活，记录感动</p>
    </div>

    <div class="grid">
        {animeList.map((anime) => (
            <div class="card">
                <img src={anime.image_url || 'https://via.placeholder.com/300x400?text=No+Image'} alt={anime.title} class="cover" />
                <div class="content">
                    <span class="status-badge">{anime.status}</span>
                    <h2 class="title">{anime.title}</h2>
                    <div class="scores">
                        <span class="my-score">⭐ 我评: {anime.score}</span>
                        {anime.bgm_score && <span class="bgm-score">📍 Bgm: {anime.bgm_score}</span>}
                    </div>
                    <p class="review">{anime.review}</p>
                </div>
            </div>
        ))}
    </div>

    <div class="footer">
        Powered by Astro & Cloudflare D1 | 2026
    </div>
</body>
</html>
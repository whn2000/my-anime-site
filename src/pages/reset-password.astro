---
export const prerender = false;
import { env } from "cloudflare:workers";
import { hashPassword, checkVerificationCode } from "../lib/auth.js";

const db = env.DB;
let message = "";
let messageType = "error";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const email = data.get("email")?.toString().trim();
  const verifyCode = data.get("verify_code")?.toString().trim();
  const newPassword = data.get("new_password")?.toString();

  if (!email || !verifyCode || !newPassword) {
    message = "请填写完整信息";
  } else if (newPassword.length < 6) {
    message = "新密码长度至少需要 6 个字符";
  } else {
    // 校验修改密码专用的验证码
    const isCodeValid = await checkVerificationCode(db, email, verifyCode, 'reset');
    
    if (!isCodeValid) {
      message = "验证码错误或已过期";
    } else {
      // 验证码通过，更新密码
      const passwordHash = await hashPassword(newPassword);
      await db.prepare("UPDATE users SET password_hash = ? WHERE email = ?").bind(passwordHash, email).run();
      
      message = "密码重置成功，请去登录";
      messageType = "success";
    }
  }
}
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>重置密码 - MyAnimeList</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', 'Noto Sans SC', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab); background-size: 400% 400%; animation: gradientBG 15s ease infinite; padding: 20px; }
        @keyframes gradientBG { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        .auth-card { background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.3); border-radius: 28px; padding: 45px 40px; width: 100%; max-width: 420px; box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15); animation: slideUp 0.6s ease; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        .form-group { margin-bottom: 18px; position: relative; }
        .form-group label { display: block; font-size: 0.8rem; font-weight: 600; color: #636e72; margin-bottom: 8px; }
        .form-group input { width: 100%; padding: 14px 18px; border: 2px solid #e9ecef; border-radius: 14px; font-size: 0.95rem; font-family: inherit; transition: all 0.3s; background: rgba(255, 255, 255, 0.8); outline: none; }
        .form-group input:focus { border-color: #f09199; }
        .send-code-btn { position: absolute; right: 5px; top: 31px; padding: 8px 12px; background: #e9ecef; color: #2d3436; border: none; border-radius: 10px; font-size: 0.8rem; cursor: pointer; transition: 0.2s; }
        .submit-btn { width: 100%; padding: 15px; background: linear-gradient(135deg, #f09199, #e73c7e); color: white; border: none; border-radius: 14px; font-size: 1rem; font-weight: 700; cursor: pointer; margin-top: 10px; }
        .message { text-align: center; padding: 12px; border-radius: 12px; margin-bottom: 18px; font-size: 0.85rem; }
        .message.error { background: rgba(214, 48, 49, 0.1); color: #d63031; }
        .message.success { background: rgba(0, 184, 148, 0.1); color: #00b894; }
        .auth-footer { text-align: center; margin-top: 22px; font-size: 0.85rem; color: #636e72; }
        .auth-footer a { color: #e73c7e; text-decoration: none; font-weight: 600; }
        .code-input-wrapper { display: flex; gap: 10px; }
        .code-input-wrapper input { flex: 1; }
    </style>
</head>
<body>
    <div class="auth-card">
        <h1 style="text-align:center; margin-bottom: 30px;">找回密码</h1>
        
        {message && <div class={`message ${messageType}`}>{message}</div>}

        <form method="POST">
            <div class="form-group">
                <label>注册邮箱</label>
                <input type="email" id="email" name="email" placeholder="输入绑定的邮箱" required />
            </div>

            <div class="form-group">
                <label>邮箱验证码</label>
                <div class="code-input-wrapper">
                    <input type="text" name="verify_code" placeholder="6位数验证码" required autocomplete="off" maxlength="6" />
                    <button type="button" id="send-code-btn" class="send-code-btn" style="position:static; margin-top:3px; height: 46px;">获取验证码</button>
                </div>
            </div>

            <div class="form-group">
                <label>新密码</label>
                <input type="password" name="new_password" placeholder="设置新密码" required minlength="6" />
            </div>

            <button type="submit" class="submit-btn">重置密码</button>
        </form>

        <div class="auth-footer">
            <a href="/login">← 返回登录</a>
        </div>
    </div>

    <script is:inline>
        document.getElementById('send-code-btn').addEventListener('click', async function() {
            const email = document.getElementById('email').value.trim();
            if (!email) return alert('请先填写邮箱地址');

            const btn = this;
            btn.disabled = true;
            btn.innerText = '发送中...';

            try {
                const res = await fetch('/api/send-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email, purpose: 'reset' })
                });

                const data = await res.json();
                
                if (res.ok) {
                    alert('验证码发送成功');
                    let countdown = 60;
                    const timer = setInterval(() => {
                        btn.innerText = `${countdown}s 后重发`;
                        countdown--;
                        if (countdown < 0) {
                            clearInterval(timer);
                            btn.disabled = false;
                            btn.innerText = '获取验证码';
                        }
                    }, 1000);
                } else {
                    alert(data.error || '发送失败');
                    btn.disabled = false;
                    btn.innerText = '获取验证码';
                }
            } catch (err) {
                alert('网络错误');
                btn.disabled = false;
                btn.innerText = '获取验证码';
            }
        });
    </script>
</body>
</html>

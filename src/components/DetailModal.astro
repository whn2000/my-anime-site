---
export interface Props {
    currentUser: any;
}
const { currentUser } = Astro.props;
---
<dialog id="detail-modal">
    <div class="modal-body">
        <button class="close-btn" id="close-modal" aria-label="关闭" title="关闭">✕</button>

        <div class="modal-header-sec">
            <img id="m-img" class="modal-img" src="" alt="Anime Cover" />
            <div class="modal-info-wrap">
                <h2 id="m-title" style="margin-bottom: 10px; font-size:1.8rem; color:var(--text-main); text-shadow:0 2px 10px rgba(0,0,0,0.2);">
                </h2>
                <div id="m-info" style="margin-bottom: 15px; font-weight: bold; color: var(--primary);"></div>
                <div id="m-meta" style="margin-bottom: 20px; font-size: 0.95rem; color: var(--text-main); line-height: 1.8; background: var(--meta-bg); padding: 15px; border-radius: 12px; border-left: 3px solid var(--primary);"></div>

                <div class="section-title">✨ 管理员独立评分</div>
                <div id="m-scores-list"></div>
                
                {currentUser && (currentUser.role === 'owner' || currentUser.role === 'admin') && (
                    <button id="m-toggle-edit" class="comment-btn" style="margin-top: 10px; font-size: 0.8rem; padding: 6px 12px; background: var(--meta-bg); border: 1px solid var(--glass-border); color: var(--text-main);">
                        ✏️ 修改我的评分/评价
                    </button>
                )}
            </div>
        </div>

        {currentUser && (currentUser.role === 'owner' || currentUser.role === 'admin') && (
            <div id="m-edit-section" style="display:none; margin-bottom: 30px; background: rgba(251, 146, 158, 0.05); padding: 25px; border-radius: 20px; border: 1px solid var(--primary); position: relative;">
                <div class="section-title" style="margin-top:0; color: var(--primary); border-color: var(--primary);">✍️ 编辑我的见解</div>
                <div style="display:flex; gap:15px; align-items:center; margin-bottom:15px;">
                    <label style="font-size:0.9rem; font-weight:bold;">评分 (0-10):</label>
                    <input type="number" id="m-edit-score" step="0.1" min="0" max="10" 
                        style="width:100px; padding:10px; border-radius:10px; border:1px solid var(--glass-border); background:var(--input-bg); color:var(--text-main); font-weight:bold; text-align:center;" />
                    <span style="font-size:0.8rem; opacity:0.7;">10 分制，可带一位小数</span>
                </div>
                <textarea id="m-edit-review" class="comment-textarea" rows="4" 
                    placeholder="在这里写下您对该作品的深度评价..." 
                    style="background: var(--input-bg); font-size: 0.95rem;"></textarea>
                <div style="display:flex; gap:10px; margin-top:15px;">
                    <button id="m-save-edit" class="comment-btn" style="flex:1;">保存修改</button>
                    <button id="m-cancel-edit" class="comment-btn" style="background:var(--meta-bg); color:var(--text-main); flex:1;">取消</button>
                </div>
            </div>
        )}

        <div class="section-title">💬 讨论区</div>
        <div id="loading-indicator" style="display:none;">加载中...</div>
        <div id="m-comments-list"></div>

        <div class="comment-form">
            <textarea
                id="comment-input"
                class="comment-textarea"
                rows="3"
                placeholder={currentUser ? "写下你的评论..." : "请先登录后再发表评论"}
                disabled={!currentUser}></textarea>
            <button
                id="submit-comment"
                class="comment-btn"
            >
                {currentUser ? "发表评论" : "去登录"}
            </button>
        </div>
    </div>
</dialog>

<script is:inline define:vars={{ currentUser }}>
    const modal = document.getElementById("detail-modal");
    const closeBtn = document.getElementById("close-modal");
    let currentAnimeId = null;

    // 获取评论和评分数据
    async function fetchComments(animeId) {
        document.getElementById("loading-indicator").style.display = "block";
        document.getElementById("m-scores-list").innerHTML = "";
        document.getElementById("m-comments-list").innerHTML = "";

        try {
            const res = await fetch(`/api/comments?anime_id=${animeId}`);
            const data = await res.json();
            renderScores(data.scores);
            renderComments(data.comments, data.currentUser);
            
            // 如果是管理员，预填编辑表单
            if (currentUser && (currentUser.role === 'owner' || currentUser.role === 'admin')) {
                const myScore = data.scores.find(s => s.username === currentUser.username);
                document.getElementById("m-edit-score").value = myScore ? myScore.score : "";
                document.getElementById("m-edit-review").value = myScore ? (myScore.review || "") : "";
            }
        } catch (e) {
            console.error("加载失败", e);
        } finally {
            document.getElementById("loading-indicator").style.display = "none";
        }
    }

    function getRoleTagHTML(role) {
        if (role === "owner") return `<span class="owner-tag">站长</span>`;
        if (role === "admin") return `<span class="user-tag">管理员</span>`;
        return "";
    }

    function renderScores(scores) {
        const container = document.getElementById("m-scores-list");
        if (!scores || scores.length === 0) {
            container.innerHTML = '<div style="color:#999; font-size:0.9rem;">暂无评分</div>';
            return;
        }
        container.innerHTML = scores.map(s => `
            <div class="score-item">
                <div class="score-header">
                    <div><b>${s.username}</b> ${getRoleTagHTML(s.role)}</div>
                    <div style="color: #fd9644; font-weight:bold;">⭐ ${s.score}</div>
                </div>
                ${s.review ? `<div style="font-size:0.9rem; margin-top:5px; color:#555;">${s.review}</div>` : ""}
            </div>
        `).join("");
    }

    function renderComments(comments, user) {
        const container = document.getElementById("m-comments-list");
        if (!comments || comments.length === 0) {
            container.innerHTML = '<div style="color:#999; font-size:0.9rem; margin-bottom: 20px;">还没有人评论，快来抢沙发！</div>';
            return;
        }

        container.innerHTML = comments.map((c) => {
            const canDelete = user && (user.role === "owner" || user.role === "admin" || user.id === c.user_id);
            return `
                <div class="comment-item">
                    <div class="comment-meta">
                        <b>${c.username}</b> ${getRoleTagHTML(c.role)}
                        <span style="margin-left:10px; opacity:0.7;">${new Date(c.created_at + "Z").toLocaleString("zh-CN")}</span>
                    </div>
                    <div class="comment-text">${c.content}</div>
                    ${canDelete ? `<button class="del-comment-btn" aria-label="删除评论" onclick="deleteComment(${c.id})">删除</button>` : ""}
                </div>
            `;
        }).join("");
    }

    document.getElementById("submit-comment").addEventListener("click", async () => {
        if (!currentUser) {
            window.location.href = "/login";
            return;
        }

        const input = document.getElementById("comment-input");
        const content = input.value.trim();
        if (!content) return alert("评论内容不能为空");

        try {
            const res = await fetch("/api/comments", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ anime_id: currentAnimeId, content }),
            });
            const data = await res.json();
            if (res.ok) {
                input.value = "";
                fetchComments(currentAnimeId);
            } else {
                alert(data.error || "评论失败");
            }
        } catch (e) {
            alert("网络错误");
        }
    });

    window.deleteComment = async function (commentId) {
        if (!confirm("确定删除这条评论吗？")) return;
        try {
            const res = await fetch("/api/comments", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ comment_id: commentId }),
            });
            if (res.ok) {
                fetchComments(currentAnimeId);
            } else {
                const data = await res.json();
                alert(data.error || "删除失败");
            }
        } catch (e) {
            alert("网络错误");
        }
    };

    function openModal(data, forceEdit = false) {
        currentAnimeId = data.id;
        document.getElementById("m-img").src = data.img;
        document.getElementById("m-title").innerText = data.title;
        document.getElementById("m-info").innerText = `综合平均分: ${data.score} / Bangumi: ${data.bgm}`;
        document.getElementById("m-meta").innerHTML = `
            <div style="font-size:0.9rem; margin-bottom:10px; opacity:0.85; border-bottom:1px solid var(--glass-border); padding-bottom:10px;"><i>${data.summary}</i></div>
            <div><b>🎬 制作：</b> ${data.std}</div>
            <div><b>🎥 导演：</b> ${data.dir}</div>
            <div><b>🎙️ 声优：</b> ${data.vas}</div>
        `;
        document.getElementById("m-scores-list").innerHTML = "";
        document.getElementById("m-comments-list").innerHTML = "";

        // 重置编辑状态
        const editSec = document.getElementById("m-edit-section");
        if (editSec) editSec.style.display = forceEdit ? "block" : "none";

        fetchComments(currentAnimeId);
        modal.showModal();
    }

    document.querySelectorAll(".title").forEach((btn) => {
        btn.addEventListener("click", () => openModal(btn.dataset));
    });

    // 绑定卡片上的快速编辑按钮
    document.addEventListener('click', (e) => {
        const editBtn = e.target.closest('.quick-edit-btn');
        if (editBtn) {
            const card = editBtn.closest('.card');
            const titleEl = card.querySelector('.title');
            if (titleEl) {
                openModal(titleEl.dataset, true);
            }
        }
    });

    // 管理员编辑逻辑
    if (currentUser && (currentUser.role === 'owner' || currentUser.role === 'admin')) {
        const toggleBtn = document.getElementById("m-toggle-edit");
        const cancelBtn = document.getElementById("m-cancel-edit");
        const saveBtn = document.getElementById("m-save-edit");
        const editSection = document.getElementById("m-edit-section");

        toggleBtn.onclick = () => { editSection.style.display = "block"; editSection.scrollIntoView({ behavior: 'smooth' }); };
        cancelBtn.onclick = () => { editSection.style.display = "none"; };

        saveBtn.onclick = async () => {
            const score = document.getElementById("m-edit-score").value;
            const review = document.getElementById("m-edit-review").value;
            
            if (!score) return alert("评分不能为空");
            
            saveBtn.disabled = true;
            saveBtn.innerText = "保存中...";
            
            try {
                const res = await fetch("/api/score", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ anime_id: currentAnimeId, score, review }),
                });
                const data = await res.json();
                if (res.ok) {
                    window.showToast?.("✨ 评分与评论已保存！");
                    editSection.style.display = "none";
                    fetchComments(currentAnimeId);
                } else {
                    alert(data.error || "保存失败");
                }
            } catch (e) {
                alert("网络错误");
            } finally {
                saveBtn.disabled = false;
                saveBtn.innerText = "保存修改";
            }
        };
    }

    closeBtn.onclick = () => {
        modal.close();
        currentAnimeId = null;
    };
    modal.addEventListener("click", (e) => e.target === modal && modal.close());

    // 主题切换
    const themeBtn = document.getElementById("theme-toggle");
    function updateThemeBtn(theme) { themeBtn.innerText = theme === "dark" ? "🌙 暗" : "☀️ 明"; }
    updateThemeBtn(document.documentElement.getAttribute("data-theme"));
    themeBtn.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-theme");
        const next = current === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", next);
        localStorage.setItem("site-theme", next);
        updateThemeBtn(next);
    });
</script>

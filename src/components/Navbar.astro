---
import { getRoleLabel, hasRole } from "../lib/auth.js";
export interface Props {
    currentUser: any;
}
const { currentUser } = Astro.props;
---
<nav class="navbar" aria-label="主导航">
    {
        currentUser ? (
            <>
                <div class="user-badge">
                    {currentUser.username} ({getRoleLabel(currentUser.role)})
                </div>
                {hasRole(currentUser, ["owner", "admin"]) && (
                    <a href="/admin">管理后台</a>
                )}
                <a href="/logout">登出</a>
            </>
        ) : (
            <>
                <a href="/login">登录</a>
                <a href="/register">注册</a>
            </>
        )
    }
    <select
        id="theme-select"
        class="user-badge"
        aria-label="选择主题"
        title="选择主题模式"
        style="cursor:pointer; border:1px solid var(--glass-border); padding: 4px 8px; border-radius: 100px; outline: none; display: inline-block; background: var(--meta-bg); color: var(--text-main); font-weight: bold; font-family: inherit; font-size: 0.8rem;"
    >
        <option value="dark">🌙 暗色</option>
        <option value="light">☀️ 亮色</option>
        <option value="miku">🧪 葱绿</option>
    </select>
</nav>

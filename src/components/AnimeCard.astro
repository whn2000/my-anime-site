---
export interface Props {
    anime: any;
    theme: { color: string; bg: string };
    index: number;
    currentUser?: any;
}

const { anime, theme, index, currentUser } = Astro.props;
const isAdmin = currentUser && (currentUser.role === 'owner' || currentUser.role === 'admin');
const proxyImg = anime.image_url ? `/api/image?url=${encodeURIComponent(anime.image_url)}` : '';
const progress = anime.progress || 0;
const totalEps = anime.total_episodes || 0;
const showProgress = anime.status === '正在追' && totalEps > 0;
const progressPct = totalEps > 0 ? Math.round((progress / totalEps) * 100) : 0;

// Strip markdown syntax for card preview display
function stripMarkdown(text: string): string {
    return text
        .replace(/#{1,6}\s*/g, '')
        .replace(/\*\*(.+?)\*\*/g, '$1')
        .replace(/\*(.+?)\*/g, '$1')
        .replace(/~~(.+?)~~/g, '$1')
        .replace(/`(.+?)`/g, '$1')
        .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
        .replace(/!\[([^\]]*)\]\([^)]+\)/g, '$1')
        .replace(/>\s*/g, '')
        .replace(/[-*+]\s+/g, '')
        .replace(/\d+\.\s+/g, '')
        .replace(/\n{2,}/g, ' ')
        .replace(/\n/g, ' ')
        .trim();
}
const reviewText = stripMarkdown(anime.latest_review || anime.review || '暂无评价...');
---
<div class="card" style={`animation-delay: ${index * 0.1}s`}>
    <div class="cover-wrapper">
        <span
            class="status-badge"
            style={`background: ${theme.bg}; color: ${theme.color}; border: 1px solid ${theme.color}`}
        >
            {anime.status}
        </span>
        {proxyImg ? (
            <img
                src={proxyImg}
                loading="lazy"
                alt={`Cover image for ${anime.title}`}
                class="cover"
            />
        ) : (
            <div class="cover" style="background: var(--meta-bg); display: flex; align-items: center; justify-content: center; font-size: 3rem;">🌸</div>
        )}
        {isAdmin && (
            <button 
                class="quick-edit-btn" 
                data-id={anime.id}
                title="快速修改评分/评价"
            >
                📝
            </button>
        )}
    </div>

    <style>
        .quick-edit-btn {
            position: absolute;
            bottom: 15px;
            left: 15px;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            color: var(--text-main);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 5;
            opacity: 0;
            transform: scale(0.8) translateY(10px);
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            font-size: 1.1rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .card:hover .quick-edit-btn {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
        .quick-edit-btn:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: scale(1.1);
        }
    </style>
    <div class="content">
        <h2
            class="title"
            data-id={anime.id}
            data-title={anime.title}
            data-img={proxyImg}
            data-score={anime.avg_score || "暂无"}
            data-bgm={anime.bgm_score}
            data-dir={anime.director || "未知"}
            data-vas={anime.voice_actors || "未知"}
            data-std={anime.studio || "未知"}
            data-summary={anime.review || "暂无简介..."}
        >
            {anime.title}
        </h2>
        <div class="scores">
            <span class="score-pill" style="color: #fd9644;">
                ⭐ 平均分: {anime.avg_score || "-"}
            </span>
            <span class="score-pill" style="color: #a29bfe;">
                📍 bgm: {anime.bgm_score}
            </span>
        </div>
        <div class="meta-tags">
            {anime.studio && (
                <span class="meta-tag">🏢 {anime.studio}</span>
            )}
            {anime.director && (
                <span class="meta-tag">🎬 {anime.director}</span>
            )}
        </div>

        {showProgress && (
            <div class={`progress-wrap ${progress >= totalEps ? 'is-complete' : ''}`} data-anime-id={anime.id} data-total={totalEps}>
                <div class="progress-info">
                    <span class="progress-label">
                        📺
                        <span class="ep-count" id={`prog-text-${anime.id}`}>{progress}</span>
                        <span class="ep-total">/ {totalEps} 集</span>
                    </span>
                    {isAdmin && (
                        <div class="progress-btns">
                            <button
                                class="progress-btn progress-dec"
                                data-anime-id={anime.id}
                                data-action="decrement"
                                title="回退一集 -1"
                                aria-label="减少一集进度"
                            >−1</button>
                            <button
                                class="progress-btn progress-inc"
                                data-anime-id={anime.id}
                                data-action="increment"
                                title="看完一集 +1"
                                aria-label="增加一集进度"
                            >+1</button>
                        </div>
                    )}
                </div>
                <div class="progress-bar-bg" id={`prog-track-${anime.id}`}>
                    <div class="progress-bar-fill" id={`prog-bar-${anime.id}`} style={`width: ${progressPct}%`}></div>
                    {isAdmin && (
                        <input
                            type="range"
                            class="progress-slider"
                            id={`prog-slider-${anime.id}`}
                            data-anime-id={anime.id}
                            min="0"
                            max={totalEps}
                            value={progress}
                            aria-label="拖动设置观看进度"
                        />
                    )}
                </div>
            </div>
        )}

        <p class="review">{reviewText}</p>
    </div>
</div>
